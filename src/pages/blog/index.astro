---
/**
 * Blog Index — /blog
 * Lists all published blog posts from the blog content collection.
 * Posts live in src/content/blog/*.mdx.
 * Uses getCollection('blog') from astro:content — Astro-native pattern.
 * Hero background via import.meta.glob + getImage() — consistent with site.
 */
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import StatBar from '../../components/ui/StatBar.astro';
import TrustBar from '../../components/ui/TrustBar.astro';
import { breadcrumbSchema } from '../../lib/schema';
import { cms } from '../../lib/cms';
import { resolveCmsImage } from '../../lib/images';

const content = cms.pages.blog;

// ─── Hero image ───────────────────────────────
const heroAsset = resolveCmsImage(content.hero.image);
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, format: 'webp', quality: 80 })
  : null;

// ─── Blog posts ───────────────────────────────
// Filter drafts in production; include all in dev
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort newest first
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const crumbs = [
  { name: cms.globalCtas.breadcrumbHomeLabel, url: '/' },
  { name: content.breadcrumbLabel, url: '/blog' },
];

const schemas = [breadcrumbSchema(crumbs)];

const topics = content.topics.items;
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`blog-hero${optimizedHero ? ' blog-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="blog-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container blog-hero-inner">
      <span class="eyebrow">{content.hero.eyebrow}</span>
      <h1>{content.hero.heading.split('\n').map((line, index) => <>{index > 0 && <br />}{line}</>)}</h1>
      <p class="blog-intro">{content.hero.body}</p>
    </div>
  </section>

  <StatBar />

  <!-- ═══ POSTS ════════════════════════════════ -->
  {posts.length > 0 && (
    <section class="section-y" aria-labelledby="posts-heading">
      <div class="container">
        <span class="eyebrow">{content.posts.eyebrow}</span>
        <h2 id="posts-heading">{content.posts.heading}</h2>
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card card">
              <div class="post-card-body">
                <span class="post-category tag tag-gold">{post.data.category}</span>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="post-date"
                  >
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="post-read-more">
                    {content.posts.readMoreLabel}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ TOPICS ═══════════════════════════════ -->
  <section class="section-y topics-band" aria-labelledby="topics-heading">
    <div class="container">
      <span class="eyebrow">{content.topics.eyebrow}</span>
      <h2 id="topics-heading">{content.topics.heading}</h2>
      <div class="topics-grid">
        {topics.map((topic) => (
          <div class="topic-card">
            <h3 class="topic-label">{topic.title}</h3>
            <p class="topic-desc">{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />

  <CtaStrip
    heading={content.finalCta.heading}
    subtext={content.finalCta.body}
    primaryLabel={content.finalCta.primaryCta.label}
    primaryHref={content.finalCta.primaryCta.href}
    secondaryLabel={content.finalCta.secondaryCta.label}
    secondaryHref={content.finalCta.secondaryCta.href}
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .blog-hero {
    position: relative;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-hero-has-image {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .blog-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .blog-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .blog-hero-inner {
    position: relative;
    z-index: 1;
  }

  .blog-hero h1 { max-width: 24ch; margin: 0.5rem 0 1rem; }
  .blog-intro   { max-width: 58ch; font-size: 1.0625rem; }

  /* ─── Posts grid ─────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .post-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-category { margin-bottom: 0.75rem; }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.25;
    margin: 0 0 0.75rem;
    transition: color var(--transition-base);
  }

  .post-card:hover .post-title { color: var(--color-gold); }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .post-date {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: color var(--transition-base), gap var(--transition-base);
  }

  .post-card:hover .post-read-more {
    color: var(--color-gold);
    gap: 0.45rem;
  }

  /* ─── Topics ─────────────────────────────────── */
  .topics-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .topic-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: border-color var(--transition-smooth);
  }

  .topic-card:hover { border-color: var(--color-border-gold); }

  .topic-label {
    font-size: 1.0625rem;
    margin: 0 0 0.5rem;
  }

  .topic-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .posts-grid  { grid-template-columns: repeat(2, 1fr); }
    .topics-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .posts-grid  { grid-template-columns: 1fr; }
    .topics-grid { grid-template-columns: 1fr; }
  }
</style>

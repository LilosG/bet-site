---
/**
 * Blog Index — /blog
 * Lists all published blog posts from the blog content collection.
 * Posts live in src/content/blog/*.mdx.
 * Uses getCollection('blog') from astro:content — Astro-native pattern.
 * Hero background via import.meta.glob + getImage() — consistent with site.
 */
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import { breadcrumbSchema } from '../../lib/schema';

// ─── Hero image ───────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/*.webp',
  { eager: true }
);

const heroAsset = allImages['../../assets/images/hero-equipment.webp']?.default;
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, format: 'webp', quality: 80 })
  : null;

// ─── Blog posts ───────────────────────────────
// Filter drafts in production; include all in dev
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort newest first
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
];

const schemas = [breadcrumbSchema(crumbs)];

const topics = [
  { label: 'Buyer Guides',      desc: 'How to evaluate, size, and purchase used brewing equipment.' },
  { label: 'Equipment Types',   desc: 'What each piece of equipment does and how it fits your operation.' },
  { label: 'Industry News',     desc: 'Auction announcements, market trends, and inventory updates.' },
  { label: 'Rigging & Install', desc: 'What rigging and installation actually involves and what to budget.' },
  { label: 'Consignment',       desc: 'How to liquidate equipment intelligently.' },
  { label: 'Brewery Start-Up',  desc: 'Capacity planning, equipment sourcing strategy, and timeline.' },
];
---

<Layout
  title="Brewery Equipment Blog — Buyer Guides, News & Resources | Beverage Equipment Traders"
  description="Expert guides on buying used brewery equipment, rigging and installation, consignment, and more. Written by former brewery operators. Beverage Equipment Traders, San Marcos, CA."
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`blog-hero${optimizedHero ? ' blog-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="blog-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container blog-hero-inner">
      <span class="eyebrow">Resources</span>
      <h1>Brewery Equipment:<br />The Operator's Perspective.</h1>
      <p class="blog-intro">
        Practical guides on buying, moving, and selling brewery and beverage equipment.
        Written by people who have actually run production facilities.
      </p>
    </div>
  </section>

  <hr class="section-rule" />

  <!-- ═══ POSTS ════════════════════════════════ -->
  {posts.length > 0 && (
    <section class="section-y" aria-labelledby="posts-heading">
      <div class="container">
        <span class="eyebrow">Latest Articles</span>
        <h2 id="posts-heading">From the Trade Desk</h2>
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card card">
              <div class="post-card-body">
                <span class="post-category tag tag-gold">{post.data.category}</span>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="post-date"
                  >
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="post-read-more">
                    Read More
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ TOPICS ═══════════════════════════════ -->
  <section class="section-y topics-band" aria-labelledby="topics-heading">
    <div class="container">
      <span class="eyebrow">Content Categories</span>
      <h2 id="topics-heading">What We Write About</h2>
      <div class="topics-grid">
        {topics.map((topic) => (
          <div class="topic-card">
            <h3 class="topic-label">{topic.label}</h3>
            <p class="topic-desc">{topic.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip
    heading="Questions our articles don't answer?"
    subtext="Our trade desk is available by phone or email. We respond within one business day."
    primaryLabel="Contact the Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Browse Equipment"
    secondaryHref="/equipment"
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .blog-hero {
    position: relative;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-hero-has-image {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .blog-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .blog-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(11,12,15,0.96) 0%, rgba(11,12,15,0.88) 45%, rgba(11,12,15,0.55) 75%, rgba(11,12,15,0.2) 100%),
      linear-gradient(to bottom, rgba(11,12,15,0.3) 0%, transparent 30%, rgba(11,12,15,0.5) 100%);
  }

  .blog-hero-inner {
    position: relative;
    z-index: 1;
  }

  .blog-hero h1 { max-width: 24ch; margin: 0.5rem 0 1rem; }
  .blog-intro   { max-width: 58ch; font-size: 1.0625rem; }

  /* ─── Posts grid ─────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .post-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-category { margin-bottom: 0.75rem; }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.25;
    margin: 0 0 0.75rem;
    transition: color var(--transition-base);
  }

  .post-card:hover .post-title { color: var(--color-gold); }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .post-date {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: color var(--transition-base), gap var(--transition-base);
  }

  .post-card:hover .post-read-more {
    color: var(--color-gold);
    gap: 0.45rem;
  }

  /* ─── Topics ─────────────────────────────────── */
  .topics-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .topic-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: border-color var(--transition-smooth);
  }

  .topic-card:hover { border-color: var(--color-border-gold); }

  .topic-label {
    font-size: 1.0625rem;
    margin: 0 0 0.5rem;
  }

  .topic-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .posts-grid  { grid-template-columns: repeat(2, 1fr); }
    .topics-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .posts-grid  { grid-template-columns: 1fr; }
    .topics-grid { grid-template-columns: 1fr; }
  }
</style>

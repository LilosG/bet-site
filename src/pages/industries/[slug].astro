---
/**
 * Industries Page — /industries/[slug]
 * Industry-specific landing page. All content from industries.ts.
 * Dark theme throughout — zero hardcoded colors, zero bg-light sections.
 */
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import { INDUSTRIES } from '../../data/industries';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { SERVICES } from '../../data/services';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';

export async function getStaticPaths() {
  return INDUSTRIES.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;

const relatedEquipment = industry.relevantEquipment
  .map((slug) => EQUIPMENT_CATEGORIES.find((c) => c.slug === slug))
  .filter(Boolean);

const relatedServices = industry.relevantServices
  .map((slug) => SERVICES.find((s) => s.slug === slug))
  .filter(Boolean);

const crumbs = [
  { name: 'Home',       url: '/' },
  { name: 'Industries', url: '/industries' },
  { name: industry.name, url: `/industries/${industry.slug}` },
];

const schemas = [
  breadcrumbSchema(crumbs),
  ...(industry.faqs?.length ? [faqSchema(industry.faqs)] : []),
];
---

<Layout
  title={industry.metaTitle}
  description={industry.metaDescription}
  canonical={`/industries/${industry.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class="ind-hero">
    <div class="container">
      <span class="eyebrow">Industry</span>
      <h1>{industry.h1}</h1>
      <p class="ind-hero-intro">{industry.intro}</p>
      <div class="ind-hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact the Trade Desk
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/equipment" class="btn btn-outline btn-lg">Browse Equipment</a>
      </div>
    </div>
  </section>

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="ind-body-band section-y" aria-labelledby="ind-content-heading">
    <div class="container ind-content-inner">
      <div class="prose">
        <h2 id="ind-content-heading">{industry.name} — Equipment Overview</h2>
        {industry.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="ind-sidebar">
        <div class="ind-sidebar-card">
          <h3>Talk to Our Team</h3>
          <p>Our trade desk responds within one business day. Describe your equipment requirements and we will advise on current inventory.</p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">
            Contact Trade Desk
          </a>
          <a href="tel:+19498882739" class="ind-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (949) 888-2739
          </a>
        </div>
        {industry.featuredEquipmentTypes?.length > 0 && (
          <div class="ind-sidebar-types">
            <p class="ind-sidebar-label">Common Equipment Types</p>
            <ul>
              {industry.featuredEquipmentTypes.map((type) => (
                <li>{type}</li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <!-- ═══ BUYER NEEDS ════════════════════════════ -->
  {industry.buyerNeeds?.length > 0 && (
    <section class="ind-needs-band section-y" aria-labelledby="ind-needs-heading">
      <div class="container">
        <span class="eyebrow">Common Needs</span>
        <h2 id="ind-needs-heading">What {industry.shortName} Operations Typically Source</h2>
        <div class="ind-needs-grid">
          {industry.buyerNeeds.map((need) => (
            <div class="need-card">
              <h3>{need.title}</h3>
              <p>{need.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ EQUIPMENT CATEGORIES ══════════════════ -->
  {relatedEquipment.length > 0 && (
    <section class="ind-eq-band section-y" aria-labelledby="ind-eq-heading">
      <div class="container">
        <span class="eyebrow">Equipment Available</span>
        <h2 id="ind-eq-heading">Browse Equipment by Category</h2>
        <div class="ind-eq-grid">
          {relatedEquipment.map((cat) => (
            <a href={`/equipment/${cat.slug}`} class="ind-eq-card">
              <h3 class="ind-eq-title">{cat.title}</h3>
              <p class="ind-eq-desc">{cat.description}</p>
              <span class="ind-eq-cta">
                Browse {cat.title}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ SERVICES ══════════════════════════════ -->
  {relatedServices.length > 0 && (
    <section class="ind-svc-band section-y" aria-labelledby="ind-svc-heading">
      <div class="container">
        <span class="eyebrow">Services</span>
        <h2 id="ind-svc-heading">Services Available for {industry.shortName} Operations</h2>
        <div class="ind-svc-grid">
          {relatedServices.map((svc) => (
            <a href={`/services/${svc.slug}`} class="ind-svc-card">
              <h3 class="ind-svc-title">{svc.title}</h3>
              <p class="ind-svc-desc">{svc.intro}</p>
              <span class="ind-svc-cta">
                Learn More
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FAQ ════════════════════════════════════ -->
  {industry.faqs?.length > 0 && (
    <section class="ind-faq-band section-y" aria-labelledby="ind-faq-heading">
      <div class="container ind-faq-inner">
        <div class="ind-faq-header">
          <span class="eyebrow">FAQ</span>
          <h2 id="ind-faq-heading">{industry.name} — Frequently Asked Questions</h2>
        </div>
        <div class="ind-faq-list">
          {industry.faqs.map((item) => (
            <details class="ind-faq-item">
              <summary class="ind-faq-question">
                <span>{item.q}</span>
                <span class="ind-faq-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <div class="ind-faq-answer">
                <p>{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaStrip
    heading={`Ready to source equipment for your ${industry.shortName} operation?`}
    subtext="Our trade desk responds within one business day."
    primaryLabel="Contact Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Browse All Equipment"
    secondaryHref="/equipment"
  />

</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .ind-hero {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-hero h1 {
    max-width: 26ch;
    margin: 0.5rem 0 1rem;
  }

  .ind-hero-intro {
    max-width: 60ch;
    font-size: 1.0625rem;
    margin-bottom: 2rem;
  }

  .ind-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ─── Body + Sidebar ─────────────────────────── */
  .ind-body-band {
    background: var(--color-bg-2);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .ind-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .ind-sidebar-card h3 {
    font-size: 1.0625rem;
    color: var(--color-white);
    margin: 0 0 0.5rem;
  }

  .ind-sidebar-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .ind-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .ind-phone:hover { color: var(--color-gold-light); }

  .ind-sidebar-types {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }

  .ind-sidebar-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .ind-sidebar-types ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ind-sidebar-types li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .ind-sidebar-types li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: 0.75rem;
  }

  /* ─── Buyer Needs ────────────────────────────── */
  .ind-needs-band {
    border-bottom: 1px solid var(--color-border);
  }

  .ind-needs-band h2 { margin: 0.4rem 0 2rem; }

  .ind-needs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .need-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .need-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-2px);
  }

  .need-card h3 {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.625rem;
    line-height: 1.3;
  }

  .need-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
  }

  /* ─── Equipment Grid ─────────────────────────── */
  .ind-eq-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-eq-band h2 { margin: 0.4rem 0 2rem; }

  .ind-eq-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .ind-eq-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .ind-eq-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-2px);
  }

  .ind-eq-title {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
    transition: color var(--transition-base);
  }

  .ind-eq-card:hover .ind-eq-title { color: var(--color-gold); }

  .ind-eq-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
    margin: 0;
  }

  .ind-eq-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .ind-eq-card:hover .ind-eq-cta { gap: 0.45rem; color: var(--color-gold); }

  /* ─── Services Grid ──────────────────────────── */
  .ind-svc-band {
    border-bottom: 1px solid var(--color-border);
  }

  .ind-svc-band h2 { margin: 0.4rem 0 2rem; }

  .ind-svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .ind-svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .ind-svc-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-2px);
  }

  .ind-svc-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
    transition: color var(--transition-base);
  }

  .ind-svc-card:hover .ind-svc-title { color: var(--color-gold); }

  .ind-svc-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .ind-svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .ind-svc-card:hover .ind-svc-cta { gap: 0.5rem; color: var(--color-gold); }

  /* ─── FAQ ────────────────────────────────────── */
  .ind-faq-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-faq-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .ind-faq-header {
    position: sticky;
    top: 90px;
  }

  .ind-faq-header h2 { margin-top: 0; }

  .ind-faq-list {
    display: flex;
    flex-direction: column;
  }

  .ind-faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .ind-faq-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .ind-faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-white);
    transition: color var(--transition-base);
    user-select: none;
  }

  .ind-faq-question::-webkit-details-marker { display: none; }
  .ind-faq-question:hover { color: var(--color-gold); }
  details[open] .ind-faq-question { color: var(--color-gold); }

  .ind-faq-icon {
    flex-shrink: 0;
    color: var(--color-text-subtle);
    transition: transform var(--transition-smooth);
  }

  details[open] .ind-faq-icon { transform: rotate(180deg); }

  .ind-faq-answer {
    padding: 0 0 1.25rem;
    max-width: 68ch;
  }

  .ind-faq-answer p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.75;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .ind-content-inner  { grid-template-columns: 1fr; gap: 2.5rem; }
    .ind-needs-grid     { grid-template-columns: repeat(2, 1fr); }
    .ind-eq-grid        { grid-template-columns: repeat(2, 1fr); }
    .ind-svc-grid       { grid-template-columns: repeat(2, 1fr); }
    .ind-faq-inner      { grid-template-columns: 1fr; gap: 2rem; }
    .ind-faq-header     { position: static; }
  }

  @media (max-width: 640px) {
    .ind-hero-ctas  { flex-direction: column; }
    .ind-needs-grid { grid-template-columns: 1fr; }
    .ind-eq-grid    { grid-template-columns: 1fr 1fr; }
    .ind-svc-grid   { grid-template-columns: 1fr; }
  }
</style>

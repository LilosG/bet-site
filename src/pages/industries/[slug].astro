---
/**
 * Industries Page — /industries/[slug]
 * Single template generating all industry pages from data.
 * Hero image via import.meta.glob + getImage — same pattern as equipment/[slug].astro
 */
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import BuyerNeeds from '../../components/ui/BuyerNeeds.astro';
import StatBar from '../../components/ui/StatBar.astro';
import TrustBar from '../../components/ui/TrustBar.astro';
import FAQ from '../../components/ui/FAQ.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import { INDUSTRIES } from '../../data/industries';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { SERVICES } from '../../data/services';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/*.webp',
  { eager: true }
);

function getAsset(filename: string | undefined): ImageMetadata | undefined {
  if (!filename) return undefined;
  return allImages[`../../assets/images/${filename}`]?.default;
}

export async function getStaticPaths() {
  return INDUSTRIES.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;

const heroAsset = getAsset(industry.heroImage);
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1600, height: 900, format: 'webp', quality: 80 })
  : null;

const relatedEquipment = industry.relevantEquipment
  .map((slug) => EQUIPMENT_CATEGORIES.find((c) => c.slug === slug))
  .filter(Boolean);

const relatedServices = industry.relevantServices
  .map((slug) => SERVICES.find((s) => s.slug === slug))
  .filter(Boolean);

const crumbs = [
  { name: 'Home',        url: '/' },
  { name: 'Industries',  url: '/industries' },
  { name: industry.name, url: `/industries/${industry.slug}` },
];

const schemas = [
  breadcrumbSchema(crumbs),
  ...(industry.faqs?.length ? [faqSchema(industry.faqs)] : []),
];
---

<Layout
  title={industry.metaTitle}
  description={industry.metaDescription}
  canonical={`/industries/${industry.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`ind-hero${optimizedHero ? ' ind-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="ind-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container ind-hero-inner">
      <span class="eyebrow">Industry</span>
      <h1>{industry.h1}</h1>
      <p class="ind-hero-intro">{industry.intro}</p>
      <div class="ind-hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact the Trade Desk
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/equipment" class="btn btn-outline btn-lg">Browse Equipment</a>
      </div>
    </div>
  </section>

  <StatBar />

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="ind-body-band section-y" aria-labelledby="ind-content-heading">
    <div class="container ind-content-inner">
      <div class="prose">
        <h2 id="ind-content-heading">{industry.name} — Equipment Overview</h2>
        {industry.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="ind-sidebar">
        <div class="ind-sidebar-card">
          <h3>Talk to Our Team</h3>
          <p>Our trade desk responds within one business day. Describe your equipment requirements and we will advise on current inventory.</p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">
            Contact Trade Desk
          </a>
          <a href="tel:+19498882739" class="ind-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (949) 888-2739
          </a>
        </div>
        {industry.featuredEquipmentTypes?.length > 0 && (
          <div class="ind-sidebar-types">
            <p class="ind-sidebar-label">Common Equipment Types</p>
            <ul>
              {industry.featuredEquipmentTypes.map((type) => (
                <li>{type}</li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <!-- ═══ BUYER NEEDS ════════════════════════════ -->
  {industry.buyerNeeds?.length > 0 && (
    <BuyerNeeds
      needs={industry.buyerNeeds}
      heading={`What ${industry.shortName} Operations Typically Source`}
      eyebrow="Common Needs"
    />
  )}

  <TrustBar />

  <!-- ═══ EQUIPMENT CATEGORIES ══════════════════ -->
  {relatedEquipment.length > 0 && (
    <section class="ind-eq-band section-y" aria-labelledby="ind-eq-heading">
      <div class="container">
        <span class="eyebrow">Equipment Available</span>
        <h2 id="ind-eq-heading">Browse Equipment by Category</h2>
        <div class="ind-eq-grid">
          {relatedEquipment.map((cat) => (
            <a href={`/equipment/${cat.slug}`} class="ind-eq-card">
              <h3 class="ind-eq-title">{cat.title}</h3>
              <p class="ind-eq-desc">{cat.description}</p>
              <span class="ind-eq-cta">
                Browse {cat.title}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ SERVICES ══════════════════════════════ -->
  {relatedServices.length > 0 && (
    <section class="ind-svc-band section-y" aria-labelledby="ind-svc-heading">
      <div class="container">
        <span class="eyebrow">Services</span>
        <h2 id="ind-svc-heading">Services Available for {industry.shortName} Operations</h2>
        <div class="ind-svc-grid">
          {relatedServices.map((svc) => (
            <a href={`/services/${svc.slug}`} class="ind-svc-card">
              <div class="ind-svc-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d={svc.icon} />
                </svg>
              </div>
              <h3 class="ind-svc-title">{svc.title}</h3>
              <p class="ind-svc-desc">{svc.intro}</p>
              <span class="ind-svc-cta">
                Learn More
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FAQ ════════════════════════════════════ -->
  {industry.faqs?.length > 0 && (
    <FAQ
      items={industry.faqs}
      heading={`${industry.name} — Frequently Asked Questions`}
    />
  )}

  <!-- ═══ CTA ════════════════════════════════════ -->
  <CtaStrip
    heading={`Ready to source equipment for your ${industry.shortName} operation?`}
    subtext="Our trade desk responds within one business day."
    primaryLabel="Contact Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Browse All Equipment"
    secondaryHref="/equipment"
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .ind-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-hero-has-image {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .ind-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .ind-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .ind-hero-inner  { position: relative; z-index: 1; }
  .ind-hero h1     { max-width: 26ch; margin: 0.5rem 0 1rem; color: var(--color-white); }
  .ind-hero-intro  { max-width: 60ch; font-size: 1.0625rem; margin-bottom: 2rem; color: rgba(255,255,255,0.85); }
  .ind-hero-ctas   { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ─── Body + Sidebar ─────────────────────────── */
  .ind-body-band { background: var(--color-bg-2); border-bottom: 1px solid var(--color-border); }

  .ind-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .ind-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .ind-sidebar-card h3 { font-size: 1.0625rem; color: var(--color-heading); margin: 0 0 0.5rem; }
  .ind-sidebar-card p  { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1.25rem; }

  .ind-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .ind-phone:hover { color: var(--color-gold-light); }

  .ind-sidebar-types {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }

  .ind-sidebar-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .ind-sidebar-types ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }

  .ind-sidebar-types li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .ind-sidebar-types li::before { content: '—'; position: absolute; left: 0; color: var(--color-gold); font-size: 0.75rem; }

  /* ─── Equipment Grid ─────────────────────────── */
  .ind-eq-band {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ind-eq-band h2 { margin: 0.4rem 0 2rem; }

  .ind-eq-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }

  .ind-eq-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card-rest);
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), border-top-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .ind-eq-card:hover { border-color: var(--color-border-gold); border-top-color: var(--color-teal); transform: translateY(-2px); }

  .ind-eq-title { font-family: var(--font-ui); font-size: 0.9375rem; font-weight: 700; color: var(--color-heading); margin: 0; transition: color var(--transition-base); }
  .ind-eq-card:hover .ind-eq-title { color: var(--color-gold); }
  .ind-eq-desc  { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.5; flex: 1; margin: 0; }

  .ind-eq-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .ind-eq-card:hover .ind-eq-cta { gap: 0.45rem; color: var(--color-gold); }

  /* ─── Services Grid ──────────────────────────── */
  .ind-svc-band { border-bottom: 1px solid var(--color-border); }
  .ind-svc-band h2 { margin: 0.4rem 0 2rem; }
  .ind-svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

  .ind-svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card-rest);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), border-top-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .ind-svc-card:hover { border-color: var(--color-border-gold); border-top-color: var(--color-gold); transform: translateY(-2px); }

  .ind-svc-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 3px;
    background: var(--color-gold-dim);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.875rem;
    flex-shrink: 0;
    transition: background var(--transition-smooth);
  }

  .ind-svc-card:hover .ind-svc-icon {
    background: var(--color-teal-dim);
    color: var(--color-teal);
  }

  .ind-svc-title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-heading); margin: 0; transition: color var(--transition-base); }
  .ind-svc-card:hover .ind-svc-title { color: var(--color-gold); }
  .ind-svc-desc { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.65; flex: 1; margin: 0; }

  .ind-svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .ind-svc-card:hover .ind-svc-cta { gap: 0.5rem; color: var(--color-gold); }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .ind-content-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .ind-eq-grid        { grid-template-columns: repeat(2, 1fr); }
    .ind-svc-grid       { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .ind-hero-ctas { flex-direction: column; }
    .ind-eq-grid   { grid-template-columns: 1fr 1fr; }
    .ind-svc-grid  { grid-template-columns: 1fr; }
  }
</style>

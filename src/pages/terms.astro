---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { SITE, NAP } from '../data/site';
import { breadcrumbSchema } from '../lib/schema';
import { cms } from '../lib/cms';

const content = cms.pages.terms;
const [introBeforeUrl, introAfterUrl] = content.intro.split('{siteUrl}');
const [contactBeforeEmail, contactAfterEmail] = content.contactBody.split('{email}');

const crumbs = [
  { name: cms.globalCtas.breadcrumbHomeLabel, url: '/' },
  { name: content.breadcrumbLabel, url: '/terms' },
];
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  noindex={true}
  schemas={[breadcrumbSchema(crumbs)]}
>
  <Breadcrumb crumbs={crumbs} />
  <section class="legal-section">
    <div class="container legal-inner">
      <h1>{content.heading}</h1>
      <p class="legal-updated">{content.updated}</p>

      <p>{introBeforeUrl}<strong>{SITE.url}</strong>{introAfterUrl}</p>

      {content.sections.map(section => <><h2>{section.heading}</h2><p>{section.body}</p></>)}

      <h2>{content.contactHeading}</h2>
      <p>{contactBeforeEmail}<a href={`mailto:${NAP.email}`}>{NAP.email}</a>{contactAfterEmail}</p>
    </div>
  </section>
</Layout>

<style>
  .legal-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .legal-inner {
    max-width: 720px;
  }
  .legal-updated {
    font-size: 0.875rem;
    color: var(--color-text-subtle);
    margin-bottom: 2rem;
  }
  .legal-inner h2 {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .legal-inner a {
    color: var(--color-teal);
    text-decoration: underline;
  }
</style>

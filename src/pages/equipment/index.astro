---
/**
 * Equipment Hub — /equipment
 * H2 page listing all 8 equipment categories.
 * Hero image via import.meta.glob + getImage — same pattern as equipment/[slug].astro
 */
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import StatBar from '../../components/ui/StatBar.astro';
import TrustBar from '../../components/ui/TrustBar.astro';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { breadcrumbSchema } from '../../lib/schema';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/*.webp',
  { eager: true }
);

const heroAsset = allImages['../../assets/images/hero-equipment.webp']?.default;
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1600, height: 900, format: 'webp', quality: 80 })
  : null;

const crumbs = [
  { name: 'Home',      url: '/' },
  { name: 'Equipment', url: '/equipment' },
];

const schemas = [breadcrumbSchema(crumbs)];
---

<Layout
  title="New and Used Brewery Equipment For Sale | Shop by Category"
  description="Browse new and used brewery and beverage production equipment by category. Brewhouses, fermenters, canning lines, chillers, distilling equipment, and more. Nationwide shipping from San Marcos, CA."
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <section class={`equipment-hub-hero${optimizedHero ? ' equipment-hub-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="equipment-hub-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container equipment-hub-hero-inner">
      <span class="eyebrow">Shop Equipment</span>
      <h1>New and Used Brewery Equipment For Sale</h1>
      <p class="hub-intro">
        225+ items in stock across 8 equipment categories. Every piece photographed, documented,
        and priced. Ships nationwide from our 40,000 sq ft facility in San Marcos, CA.
      </p>
      <a
        href="https://beverageequipmenttraders.com/collections/all"
        class="btn btn-primary btn-lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Full Inventory
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <StatBar />

  <section class="section-y" aria-labelledby="categories-heading">
    <div class="container">
      <h2 id="categories-heading" class="sr-only">Equipment Categories</h2>
      <div class="category-grid">
        {EQUIPMENT_CATEGORIES.map((cat) => (
          <a href={`/equipment/${cat.slug}`} class="cat-card" aria-label={`Browse ${cat.title}`}>
            <div class="cat-card-inner">
              <span class="cat-priority-badge" data-priority={cat.priority}>
                {cat.priority === 'P0' ? 'High Availability' : 'In Stock'}
              </span>
              <h2 class="cat-card-title">{cat.h1}</h2>
              <p class="cat-card-desc">{cat.description}</p>
              <div class="cat-card-footer">
                <span class="cat-card-cta">
                  Browse Category
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
                <a
                  href={cat.shopifyCollectionUrl}
                  class="cat-card-shopify"
                  target="_blank"
                  rel="noopener noreferrer"
                  onclick="event.stopPropagation()"
                >
                  Live Inventory ↗
                </a>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />

  <CtaStrip
    heading="Ready to source equipment?"
    subtext="Our trade desk responds within one business day. Provide the equipment you need and we'll match you to current inventory or source it."
    primaryLabel="Contact the Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Get a Rigging Quote"
    secondaryHref="/contact?type=rigging"
  />
</Layout>

<style>
  .equipment-hub-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .equipment-hub-hero-has-image {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .equipment-hub-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .equipment-hub-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .equipment-hub-hero-inner { position: relative; z-index: 1; }
  .equipment-hub-hero h1    { max-width: 18ch; margin: 0.5rem 0 1rem; }
  .hub-intro                { max-width: 58ch; margin-bottom: 2rem; }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .cat-card {
    display: block;
    text-decoration: none;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card-rest);
    transition: border-color var(--transition-smooth), border-top-color var(--transition-smooth), transform var(--transition-smooth), box-shadow var(--transition-smooth);
  }

  .cat-card:hover {
    border-color: var(--color-border-gold);
    border-top-color: var(--color-gold);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .cat-card-inner {
    padding: 1.75rem 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .cat-priority-badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.175rem 0.5rem;
    border-radius: 2px;
    background: var(--color-teal-dim);
    color: var(--color-teal);
    width: fit-content;
  }

  .cat-priority-badge[data-priority="P0"] {
    background: var(--color-gold-dim);
    color: var(--color-gold);
  }

  .cat-card-title {
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    margin: 0;
    color: var(--color-heading);
    transition: color var(--transition-base);
  }

  .cat-card:hover .cat-card-title { color: var(--color-gold); }

  .cat-card-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }

  .cat-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .cat-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: gap var(--transition-base);
  }

  .cat-card:hover .cat-card-cta { gap: 0.55rem; }

  .cat-card-shopify {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .cat-card-shopify:hover { color: var(--color-text-muted); }

  @media (max-width: 768px) {
    .category-grid  { grid-template-columns: 1fr; }
    .cat-card-inner { padding: 1.25rem 1.5rem; }
  }
</style>

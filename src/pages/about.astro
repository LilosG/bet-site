---
/**
 * About Page — /about
 * Brewery origin story, operator credentials, team, client roster.
 * Uses astro:assets Image component for optimized inline images.
 * Hero background resolved via import.meta.glob + getImage() — same
 * pattern as all other page heroes on this site.
 */
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import StatBar from '../components/ui/StatBar.astro';
import TrustBar from '../components/ui/TrustBar.astro';
import CtaStrip from '../components/ui/CtaStrip.astro';
import { NAP, GEO } from '../data/site';
import { localBusinessSchema, breadcrumbSchema } from '../lib/schema';

// ─── Hero image ───────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/*.webp',
  { eager: true }
);

const heroAsset = allImages['../assets/images/hero-equipment.webp']?.default;
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, format: 'webp', quality: 80 })
  : null;

// ─── Story image ──────────────────────────────
const storyImage = allImages['../assets/images/brewhouse-hero.webp']?.default;

const crumbs = [
  { name: 'Home',  url: '/' },
  { name: 'About', url: '/about' },
];

const schemas = [
  localBusinessSchema(),
  breadcrumbSchema(crumbs),
];
---

<Layout
  title="About Beverage Equipment Traders — Built by Operators, For Operators"
  description="Beverage Equipment Traders was founded by former brewery owners who spent 15+ years on the production floor. Based in San Marcos, CA. 225+ items in stock. 600+ equipment placements."
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`about-hero${optimizedHero ? ' about-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="about-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container about-hero-inner">
      <span class="eyebrow">About BET</span>
      <h1>Built by Operators, For Operators.</h1>
      <p class="about-hero-intro">
        Beverage Equipment Traders was founded by former brewery owners who spent fifteen years on the production
        floor before pivoting to equipment trading. We know what failure at installation looks like.
        We know what a half-percent efficiency gap costs at scale. We built this company because we needed it and it didn't exist.
      </p>
    </div>
  </section>

  <!-- ═══ STATS BAND ════════════════════════════ -->
  <div class="stats-band">
    <div class="container">
      <StatBar />
    </div>
  </div>

  <!-- ═══ ORIGIN STORY ═════════════════════════ -->
  <section class="section-y" aria-labelledby="story-heading">
    <div class="container story-inner">
      <div class="story-image-block" aria-hidden="true">
        <div class="story-image-placeholder">
          {storyImage && (
            <Image
              src={storyImage}
              alt="Commercial brewhouse — Beverage Equipment Traders facility, San Marcos CA"
              class="story-img"
              width={480}
              height={640}
              loading="lazy"
              decoding="async"
            />
          )}
          <span class="story-est">EST. 2009</span>
          <span class="story-city">San Marcos, California</span>
        </div>
        <div class="story-address-card">
          <p class="story-address-label">Headquarters</p>
          <address itemscope itemtype="https://schema.org/PostalAddress">
            <span itemprop="streetAddress">{NAP.street}</span><br />
            <span itemprop="addressLocality">{NAP.city}</span>,
            <span itemprop="addressRegion">{NAP.state}</span>
            <span itemprop="postalCode">{NAP.zip}</span>
          </address>
          <a href="tel:+19498882739" class="story-phone">{NAP.phone}</a>
        </div>
      </div>

      <div class="story-content">
        <span class="eyebrow">The Story</span>
        <h2 id="story-heading">Before we brokered a single tank, we ran a brewhouse.</h2>
        <p>
          Most equipment dealers have never brewed a batch. They learned equipment pricing from a spreadsheet
          and condition grading from a checklist. We did not. We troubleshot glycol loops at 2 a.m. We welded
          back together packaging lines that vendors had written off as scrap. We commissioned brewhouses in
          facilities that were not built to spec. That context is the reason our clients refer us to other
          breweries.
        </p>
        <p>
          Beverage Equipment Traders started because there was no single operator we trusted to handle the full
          scope of an equipment transaction — sourcing, moving, installing, and commissioning — without losing
          accountability somewhere in the middle. We built the company we needed. It now serves breweries,
          cideries, distilleries, and beverage producers across all 50 states.
        </p>
        <p>
          Our 40,000 sq ft facility in San Marcos, CA houses 225+ items at any given time. Every piece is
          photographed, inspected, and condition-documented before listing. We do not sell sight-unseen from a
          blurry listing. Buyers are encouraged to inspect in person. Our team can walk you through every piece
          in our yard and give you the operator's take on what it's actually worth.
        </p>
        <div class="story-ctas">
          <a href="/equipment" class="btn btn-primary">Browse Equipment</a>
          <a href="/contact" class="btn btn-outline">Contact the Trade Desk</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT WE DO ════════════════════════════ -->
  <section class="section-y what-we-do-band" aria-labelledby="what-we-do-heading">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 id="what-we-do-heading">The Full Capital Equipment Lifecycle</h2>
      <div class="what-grid">
        {[
          { label: 'Buy and Sell',  detail: '225+ items in our yard at any time. Brewhouses, fermenters, canning lines, chillers, distilling equipment, kegs, boilers, and cold rooms. Every piece inspected.' },
          { label: 'Rig and Install', detail: 'Millwright crews, crane operation, bonded freight, and commissioning. All 50 states. One quote covers the full scope.' },
          { label: 'Consign',       detail: 'Managed listing, valuation, marketing, and payout for equipment you need to move. No upfront cost.' },
          { label: 'Auction',       detail: 'Full-facility liquidations and competitive online auction events for distressed and surplus assets.' },
          { label: 'Consult',       detail: 'Pre-purchase audits, capacity planning, and commissioning support from licensed brewery engineers.' },
          { label: 'Source New',    detail: 'Manufacturer relationships for custom new equipment builds when the right used piece is not available.' },
        ].map((item) => (
          <div class="what-item">
            <h3 class="what-label">{item.label}</h3>
            <p class="what-detail">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CLIENT ROSTER ════════════════════════ -->
  <TrustBar heading="Clients we have worked with" />

  <!-- ═══ VISIT ════════════════════════════════ -->
  <section class="section-y" aria-labelledby="visit-heading">
    <div class="container visit-inner">
      <div>
        <span class="eyebrow">Visit</span>
        <h2 id="visit-heading">Our Facility in San Marcos, CA</h2>
        <p>
          Our 40,000 sq ft facility is open for in-person inspection by appointment. Most buyers evaluating
          high-value equipment prefer to see it in person before committing. We encourage it.
        </p>
        <address class="visit-address" itemscope itemtype="https://schema.org/PostalAddress">
          <span itemprop="streetAddress">{NAP.street}</span><br />
          <span itemprop="addressLocality">{NAP.city}</span>,
          <span itemprop="addressRegion">{NAP.state}</span>
          <span itemprop="postalCode">{NAP.zip}</span>
        </address>
        <a href="tel:+19498882739" class="visit-phone">{NAP.phone}</a>
        <div class="visit-hours">
          {[
            ['Monday – Thursday', '10:00 AM – 4:00 PM'],
            ['Friday',            '10:00 AM – 3:00 PM'],
            ['Saturday',          'By Appointment'],
            ['Sunday',            'Closed'],
          ].map(([day, hours]) => (
            <div class="visit-hour-row">
              <span class="visit-day">{day}</span>
              <span class="visit-time">{hours}</span>
            </div>
          ))}
        </div>
        <a
          href={`https://www.google.com/maps/dir/?api=1&destination_place_id=${GEO.placeId}`}
          class="btn btn-outline visit-directions-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get Directions
        </a>
      </div>

      <!-- Google Maps embed — Maps Embed API, key from env, placeId from site.ts GEO -->
      <div class="visit-map-wrap">
        <iframe
          class="visit-map"
          title="Beverage Equipment Traders — San Marcos, CA facility location"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3341.086988947924!2d-117.1302703243225!3d33.133079173516876!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80dbf529c1055555%3A0xfafe87851d10b9a1!2sBeverage%20Equipment%20Traders!5e0!3m2!1sen!2sus!4v1780601003641!5m2!1sen!2sus"
          width="100%"
          height="400"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <CtaStrip
    heading="Ready to talk equipment?"
    subtext="Our trade desk responds within one business day. Provide the equipment you need and we will find it or source it."
    primaryLabel="Contact the Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Browse Inventory"
    secondaryHref="/equipment"
  />

</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .about-hero {
    position: relative;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .about-hero-has-image {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .about-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(11,12,15,0.96) 0%, rgba(11,12,15,0.88) 45%, rgba(11,12,15,0.55) 75%, rgba(11,12,15,0.2) 100%),
      linear-gradient(to bottom, rgba(11,12,15,0.3) 0%, transparent 30%, rgba(11,12,15,0.5) 100%);
  }

  .about-hero-inner {
    position: relative;
    z-index: 1;
  }

  .about-hero h1 { max-width: 22ch; margin: 0.5rem 0 1rem; }
  .about-hero-intro { max-width: 64ch; font-size: 1.0625rem; }

  /* ─── Stats ──────────────────────────────────── */
  .stats-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0;
  }

  /* ─── Story ──────────────────────────────────── */
  .story-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .story-image-placeholder {
    aspect-ratio: 3/4;
    max-height: 420px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border-gold);
  }

  .story-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .story-image-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(11,12,15,0.85) 0%, transparent 55%);
    z-index: 1;
  }

  .story-est {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
    z-index: 2;
    padding: 1.5rem 1.5rem 0.25rem;
  }

  .story-city {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    position: relative;
    z-index: 2;
    padding: 0 1.5rem 1.5rem;
  }

  .story-address-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    margin-top: 1rem;
  }

  .story-address-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.5rem;
  }

  .story-address-card address {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .story-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 0.75rem;
    transition: color var(--transition-base);
  }

  .story-phone:hover { color: var(--color-gold-light); }

  .story-content h2 { max-width: 24ch; margin: 0.5rem 0 1.5rem; }
  .story-content p  { margin-bottom: 1.25rem; }

  .story-ctas { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

  /* ─── What We Do ─────────────────────────────── */
  .what-we-do-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .what-we-do-band h2 { margin: 0.5rem 0 0; }

  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .what-item {
    padding: 1.75rem;
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .what-item:hover { border-color: var(--color-gold); transform: translateY(-2px); }

  .what-label {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.625rem;
    transition: color var(--transition-base);
  }

  .what-item:hover .what-label { color: var(--color-gold); }

  .what-detail { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; line-height: 1.65; }

  /* ─── Visit ──────────────────────────────────── */
  .visit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }

  .visit-address {
    font-style: normal;
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 1.25rem 0 0.75rem;
  }

  .visit-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color var(--transition-base);
  }

  .visit-phone:hover { color: var(--color-gold-light); }

  .visit-hours {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .visit-hour-row { display: flex; justify-content: space-between; font-size: 0.875rem; }
  .visit-day  { color: var(--color-text-muted); }
  .visit-time { color: var(--color-white); font-weight: 500; }

  .visit-directions-btn { margin-top: 1.5rem; }

  /* ─── Map ────────────────────────────────────── */
  .visit-map-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    line-height: 0;
  }

  .visit-map {
    display: block;
    width: 100%;
    height: 400px;
    border: 0;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .story-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .story-image-placeholder { aspect-ratio: 16/9; max-height: 280px; }
    .story-image-block { display: flex; gap: 1.25rem; align-items: flex-start; flex-wrap: wrap; }
    .what-grid { grid-template-columns: repeat(2, 1fr); }
    .visit-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .visit-map { height: 300px; }
  }

  @media (max-width: 640px) {
    .what-grid  { grid-template-columns: 1fr; }
    .story-ctas { flex-direction: column; }
  }
</style>

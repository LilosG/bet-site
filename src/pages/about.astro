---
/**
 * About Page — /about
 * Brewery origin story, operator credentials, team, client roster.
 * Uses astro:assets Image component for optimized inline images.
 * Hero background resolved via import.meta.glob + getImage() — same
 * pattern as all other page heroes on this site.
 */
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import StatBar from '../components/ui/StatBar.astro';
import TrustBar from '../components/ui/TrustBar.astro';
import CtaStrip from '../components/ui/CtaStrip.astro';
import { NAP, GEO } from '../data/site';
import { localBusinessSchema, breadcrumbSchema } from '../lib/schema';
import { cms } from '../lib/cms';
import { resolveCmsImage } from '../lib/images';

const content = cms.pages.about;

// ─── Hero image ───────────────────────────────
const heroAsset = resolveCmsImage(content.hero.image);
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, format: 'webp', quality: 80 })
  : null;

// ─── Story image ──────────────────────────────
const storyImage = resolveCmsImage(content.story.image);

const crumbs = [
  { name: cms.globalCtas.breadcrumbHomeLabel, url: '/' },
  { name: content.breadcrumbLabel, url: '/about' },
];

const schemas = [
  localBusinessSchema(),
  breadcrumbSchema(crumbs),
];
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`about-hero${optimizedHero ? ' about-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="about-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container about-hero-inner">
      <span class="eyebrow">{content.hero.eyebrow}</span>
      <h1>{content.hero.heading}</h1>
      <p class="about-hero-intro">{content.hero.body}</p>
    </div>
  </section>

  <StatBar />

  <!-- ═══ ORIGIN STORY ═════════════════════════ -->
  <section class="section-y" aria-labelledby="story-heading">
    <div class="container story-inner">
      <div class="story-image-block" aria-hidden="true">
        <div class="story-image-placeholder">
          {storyImage && (
            <Image
              src={storyImage}
              alt={content.story.imageAlt}
              class="story-img"
              width={480}
              height={640}
              loading="lazy"
              decoding="async"
            />
          )}
          <span class="story-est">{content.story.badgeTop}</span>
          <span class="story-city">{content.story.badgeBottom}</span>
        </div>
        <div class="story-address-card">
          <p class="story-address-label">{content.story.addressLabel}</p>
          <address itemscope itemtype="https://schema.org/PostalAddress">
            <span itemprop="streetAddress">{NAP.street}</span><br />
            <span itemprop="addressLocality">{NAP.city}</span>,
            <span itemprop="addressRegion">{NAP.state}</span>
            <span itemprop="postalCode">{NAP.zip}</span>
          </address>
          <a href={`tel:${NAP.phonePlain}`} class="story-phone">{NAP.phone}</a>
        </div>
      </div>

      <div class="story-content">
        <span class="eyebrow">{content.story.eyebrow}</span>
        <h2 id="story-heading">{content.story.heading}</h2>
        {content.story.paragraphs.map(paragraph => <p>{paragraph}</p>)}
        <div class="story-ctas">
          <a href={content.story.primaryCta.href} class="btn btn-primary">{content.story.primaryCta.label}</a>
          <a href={content.story.secondaryCta.href} class="btn btn-outline">{content.story.secondaryCta.label}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT WE DO ════════════════════════════ -->
  <section class="section-y what-we-do-band" aria-labelledby="what-we-do-heading">
    <div class="container">
      <span class="eyebrow">{content.lifecycle.eyebrow}</span>
      <h2 id="what-we-do-heading">{content.lifecycle.heading}</h2>
      <div class="what-grid">
        {content.lifecycle.items.map((item) => (
          <div class="what-item">
            <h3 class="what-label">{item.title}</h3>
            <p class="what-detail">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CLIENT ROSTER ════════════════════════ -->
  <TrustBar heading={content.trustHeading} />

  <!-- ═══ VISIT ════════════════════════════════ -->
  <section class="section-y" aria-labelledby="visit-heading">
    <div class="container visit-inner">
      <div>
        <span class="eyebrow">{content.visit.eyebrow}</span>
        <h2 id="visit-heading">{content.visit.heading}</h2>
        <p>{content.visit.body}</p>
        <address class="visit-address" itemscope itemtype="https://schema.org/PostalAddress">
          <span itemprop="streetAddress">{NAP.street}</span><br />
          <span itemprop="addressLocality">{NAP.city}</span>,
          <span itemprop="addressRegion">{NAP.state}</span>
          <span itemprop="postalCode">{NAP.zip}</span>
        </address>
        <a href={`tel:${NAP.phonePlain}`} class="visit-phone">{NAP.phone}</a>
        <div class="visit-hours">
          {content.visit.hours.map(item => (
            <div class="visit-hour-row">
              <span class="visit-day">{item.day}</span>
              <span class="visit-time">{item.label}</span>
            </div>
          ))}
        </div>
        <a
          href={`https://www.google.com/maps/dir/?api=1&destination_place_id=${GEO.placeId}`}
          class="btn btn-outline visit-directions-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          {content.visit.directionsLabel}
        </a>
      </div>

      <!-- Google Maps embed — Maps Embed API, key from env, placeId from site.ts GEO -->
      <div class="visit-map-wrap">
        <iframe
          class="visit-map"
          title={content.visit.mapTitle}
          src={content.visit.mapUrl}
          width="100%"
          height="400"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <CtaStrip
    heading={content.finalCta.heading}
    subtext={content.finalCta.body}
    primaryLabel={content.finalCta.primaryCta.label}
    primaryHref={content.finalCta.primaryCta.href}
    secondaryLabel={content.finalCta.secondaryCta.label}
    secondaryHref={content.finalCta.secondaryCta.href}
  />

</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .about-hero {
    position: relative;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .about-hero-has-image {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .about-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .about-hero-inner {
    position: relative;
    z-index: 1;
  }

  .about-hero h1 { max-width: 22ch; margin: 0.5rem 0 1rem; }
  .about-hero-intro { max-width: 64ch; font-size: 1.0625rem; }



  /* ─── Story ──────────────────────────────────── */
  .story-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .story-image-placeholder {
    aspect-ratio: 3/4;
    max-height: 420px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border-gold);
  }

  .story-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .story-image-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--hero-overlay-img-fade);
    z-index: 1;
  }

  .story-est {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
    z-index: 2;
    padding: 1.5rem 1.5rem 0.25rem;
  }

  .story-city {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    position: relative;
    z-index: 2;
    padding: 0 1.5rem 1.5rem;
  }

  .story-address-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-top: 1rem;
    box-shadow: var(--shadow-card-rest);
  }

  .story-address-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.5rem;
  }

  .story-address-card address {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .story-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 0.75rem;
    transition: color var(--transition-base);
  }

  .story-phone:hover { color: var(--color-gold-light); }

  .story-content h2 { max-width: 24ch; margin: 0.5rem 0 1.5rem; }
  .story-content p  { margin-bottom: 1.25rem; }

  .story-ctas { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

  /* ─── What We Do ─────────────────────────────── */
  .what-we-do-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .what-we-do-band h2 { margin: 0.5rem 0 0; }

  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .what-item {
    padding: 1.75rem;
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-card-rest);
    transition: border-color var(--transition-smooth), transform var(--transition-smooth), box-shadow var(--transition-smooth);
  }

  .what-item:hover { border-color: var(--color-gold); transform: translateY(-2px); box-shadow: var(--shadow-card); }

  .what-label {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.625rem;
    transition: color var(--transition-base);
  }

  .what-item:hover .what-label { color: var(--color-gold); }

  .what-detail { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; line-height: 1.65; }

  /* ─── Visit ──────────────────────────────────── */
  .visit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }

  .visit-address {
    font-style: normal;
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 1.25rem 0 0.75rem;
  }

  .visit-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color var(--transition-base);
  }

  .visit-phone:hover { color: var(--color-gold-light); }

  .visit-hours {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .visit-hour-row { display: flex; justify-content: space-between; font-size: 0.875rem; }
  .visit-day  { color: var(--color-text-muted); }
  .visit-time { color: var(--color-heading); font-weight: 500; }

  .visit-directions-btn { margin-top: 1.5rem; }

  /* ─── Map ────────────────────────────────────── */
  .visit-map-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    line-height: 0;
  }

  .visit-map {
    display: block;
    width: 100%;
    height: 400px;
    border: 0;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .story-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .story-image-placeholder { aspect-ratio: 16/9; max-height: 280px; }
    .story-image-block { display: flex; gap: 1.25rem; align-items: flex-start; flex-wrap: wrap; }
    .what-grid { grid-template-columns: repeat(2, 1fr); }
    .visit-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .visit-map { height: 300px; }
  }

  @media (max-width: 640px) {
    .what-grid  { grid-template-columns: 1fr; }
    .story-ctas { flex-direction: column; }
  }
</style>

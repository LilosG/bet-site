---
/**
 * Homepage — beverageequipmenttraders.com
 * Uses astro:assets for all images via import.meta.glob.
 * Hero background via getImage() + direct inline style on bg div.
 * Inline images via Image component.
 * All colors via design tokens — zero hardcoding.
 */
import { getImage, Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import TrustBar from '../components/ui/TrustBar.astro';
import StatBar from '../components/ui/StatBar.astro';
import EquipmentCard from '../components/ui/EquipmentCard.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';
import { NAP } from '../data/site';
import { EQUIPMENT_CATEGORIES } from '../data/equipment';
import { SERVICES } from '../data/services';
import { localBusinessSchema, breadcrumbSchema } from '../lib/schema';
import { cms } from '../lib/cms';
import { resolveCmsImage } from '../lib/images';

const content = cms.pages.home;

// ─── Hero background ─────────────────────────
const heroAsset = resolveCmsImage(content.hero.image);
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1920, height: 1080, format: 'webp', quality: 80 })
  : null;

// ─── Why BET image ────────────────────────────
const whyAsset = resolveCmsImage(content.why.image);

// ─── Rigging images ───────────────────────────
const riggingImages = content.rigging.images.map(item => ({ ...item, asset: resolveCmsImage(item.image) }));

// ─── Featured inventory ───────────────────────
const featuredItems = content.featured.items.map(item => ({
  ...item,
  condition: item.condition as 'Used' | 'New',
  imageAsset: resolveCmsImage(item.image),
}));

const schemas = [
  localBusinessSchema(),
  breadcrumbSchema([{ name: cms.globalCtas.breadcrumbHomeLabel, url: '/' }]),
];
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  schemas={schemas}
>

  <!-- ═══ HERO ═══════════════════════════════════ -->
  <section class="hero" aria-label={content.hero.ariaLabel}>
    {optimizedHero && (
      <div
        class="hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-badge animate-fade-up">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          <span>{content.hero.badgeLabels[0]}</span>
          <span class="hero-sep" aria-hidden="true">·</span>
          <span>{content.hero.badgeLabels[1]}</span>
          <span class="hero-sep" aria-hidden="true">·</span>
          <span>{content.hero.badgeLabels[2]}</span>
        </div>
        <h1 class="hero-h1 animate-fade-up delay-100">
          {content.hero.heading.split('\n').map((line, index) => <>{index > 0 && <br />}{line}</>)}
        </h1>
        <p class="hero-sub animate-fade-up delay-200">
          {content.hero.body}
        </p>
        <div class="hero-ctas animate-fade-up delay-300">
          <a href={content.hero.primaryCta.href} class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
            {content.hero.primaryCta.label}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={content.hero.secondaryCta.href} class="btn btn-outline btn-lg">{content.hero.secondaryCta.label}</a>
        </div>
        <div class="hero-stats animate-fade-up delay-400" aria-label={cms.globalCtas.statAriaLabel}>
          {content.hero.statistics.map((stat, index) => <>{index > 0 && <span class="hero-stat-div" aria-hidden="true"></span>}<div class="hero-stat"><span class="hero-stat-val">{stat.value}</span><span class="hero-stat-label">{stat.label}</span></div></>)}
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- ═══ FEATURED INVENTORY ══════════════════════ -->
  <section class="section-y featured-band" aria-labelledby="featured-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="eyebrow">{content.featured.eyebrow}</span>
          <h2 id="featured-heading">{content.featured.heading.split('\n').map((line, index) => <>{index > 0 && <br />}{line}</>)}</h2>
        </div>
        <a href={content.featured.link.href} class="section-link" target="_blank" rel="noopener noreferrer">
          {content.featured.link.label}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="cards-grid-3">
        {featuredItems.map((item) => (
          <EquipmentCard
            name={item.name}
            price={item.price}
            condition={item.condition}
            category={item.category}
            image={item.imageAsset}
            imageAlt={item.imageAlt}
            href={item.href}
          />
        ))}
      </div>
      <div class="category-pills" aria-label={content.featured.categoryAriaLabel}>
        {EQUIPMENT_CATEGORIES.map((cat) => (
          <a href={`/equipment/${cat.slug}`} class="category-pill">{cat.title}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ════════════════════════════════ -->
  <section class="section-y services-band" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="eyebrow">{content.services.eyebrow}</span>
          <h2 id="services-heading">{content.services.heading}</h2>
        </div>
        <a href={content.services.link.href} class="section-link">
          {content.services.link.label}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="services-grid">
        {SERVICES.map((service, i) => (
          <ServiceCard
            title={service.shortTitle}
            description={service.intro}
            href={`/services/${service.slug}`}
            icon={service.icon}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ WHY BET ══════════════════════════════════ -->
  <section class="section-y" aria-labelledby="why-heading">
    <div class="container why-inner">
      <div class="why-media">
        <div class="why-img-wrap">
          {whyAsset && (
            <Image
              src={whyAsset}
              alt={content.why.imageAlt}
              class="why-img"
              width={600}
              height={750}
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="why-img-badge">
            <span class="why-est">{content.why.badgeTop}</span>
            <span class="why-loc">{content.why.badgeBottom}</span>
          </div>
        </div>
      </div>
      <div class="why-content">
        <span class="eyebrow">{content.why.eyebrow}</span>
        <h2 id="why-heading">
          {content.why.heading}<br />
          <em class="text-gradient-gold">{content.why.headingAccent}</em>
        </h2>
        {content.why.paragraphs.map(paragraph => <p>{paragraph}</p>)}
        <StatBar standalone={false} />
        <div class="why-ctas">
          <a href={content.why.primaryCta.href} class="btn btn-outline">{content.why.primaryCta.label}</a>
          <a href={content.why.secondaryCta.href} class="btn btn-gold">{content.why.secondaryCta.label}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RIGGING PROOF ════════════════════════════ -->
  <section class="section-y rigging-band" aria-labelledby="rigging-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="eyebrow">{content.rigging.eyebrow}</span>
          <h2 id="rigging-heading">{content.rigging.heading}</h2>
        </div>
        <a href={content.rigging.link.href} class="section-link">
          {content.rigging.link.label}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="rigging-grid">
        {riggingImages.map(item => item.asset && <div class="rigging-img-wrap"><Image src={item.asset} alt={item.alt} class="rigging-img" width={800} height={500} loading="lazy" decoding="async" /></div>)}
      </div>
      <div class="rigging-proof-strip">
        {content.rigging.proof.map((item) => (
          <div class="rigging-proof-item">
            <span class="rigging-proof-val">{item.value}</span>
            <span class="rigging-proof-detail">{item.detail}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ NATIONAL REACH ═══════════════════════════ -->
  <section class="national-band" aria-labelledby="national-heading">
    <div class="container national-inner">
      <div class="national-content">
        <span class="eyebrow">{content.national.eyebrow}</span>
        <h2 id="national-heading" class="national-h2">
          {content.national.heading.split('\n').map((line, index) => <>{index > 0 && <br class="hide-mobile" />}{line}</>)}
        </h2>
        <p>{content.national.body}</p>
        <div class="national-cities">
          {content.national.cities.map((city) => (
            <a href={`/locations/national/${city.toLowerCase()}`} class="national-city">{city}</a>
          ))}
        </div>
      </div>
      <div class="national-stat-col" aria-hidden="true">
        <div class="national-circle">
          <span class="national-circle-num">{content.national.statisticValue}</span>
          <span class="national-circle-label">{content.national.statisticLabel}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ════════════════════════════════ -->
  <section class="section-y final-cta-section" aria-labelledby="final-cta-heading">
    <div class="container final-cta">
      <span class="eyebrow eyebrow-center">{content.finalCta.eyebrow}</span>
      <h2 id="final-cta-heading">{content.finalCta.heading}</h2>
      <p>{content.finalCta.body.split('\n').map((line, index) => <>{index > 0 && <br />}{line}</>)}</p>
      <div class="final-cta-actions">
        <a href={content.finalCta.primaryCta.href} class="btn btn-primary btn-lg">
          {content.finalCta.primaryCta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`tel:${NAP.phonePlain}`} class="btn btn-outline btn-lg">{NAP.phone}</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ═══ HERO ══════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3.5rem, 9vw, 7rem) 0 clamp(3rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--color-border);
  }

  /* Hero bg — direct inline style pattern, consistent with all other heroes on site */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center center;
    pointer-events: none;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-content { max-width: 600px; grid-column: 1; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-bg-overlay);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.3125rem 0.875rem;
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.72);
    margin-bottom: 1.375rem;
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-teal);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }

  .hero-sep { color: rgba(255,255,255,0.40); }

  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.05;
    margin: 0 0 1.125rem;
    color: var(--color-white);
    text-shadow: var(--shadow-text);
  }

  .hero-sub {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    max-width: 54ch;
    margin: 0 0 2rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.82);
  }

  .hero-ctas { display: flex; align-items: center; gap: 0.875rem; flex-wrap: wrap; margin-bottom: 2.25rem; }

  .hero-stats { display: flex; align-items: center; gap: 0; }

  .hero-stat { display: flex; flex-direction: column; align-items: flex-start; padding: 0 1.5rem 0 0; margin-right: 1.5rem; position: relative; }

  .hero-stat-val {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-gold);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-stat-label {
    font-family: var(--font-ui);
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.58);
    margin-top: 0.2rem;
    white-space: nowrap;
  }

  .hero-stat-div { width: 1px; height: 2.25rem; background: var(--color-border); flex-shrink: 0; margin-right: 1.5rem; }

  /* ═══ SHARED ═════════════════════════════════════ */
  .section-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; margin-bottom: 2.25rem; }
  .section-header h2 { margin: 0.3rem 0 0; }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--transition-base), gap var(--transition-base);
  }

  .section-link:hover { color: var(--color-gold); gap: 0.55rem; }

  /* ═══ FEATURED ═══════════════════════════════════ */
  .featured-band { background: var(--color-bg-2); border-bottom: 1px solid var(--color-border); }

  .cards-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.125rem; margin-bottom: 1.75rem; }

  .category-pills { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 1.125rem; border-top: 1px solid var(--color-border); }

  .category-pill {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.3rem 0.875rem;
    transition: color var(--transition-base), border-color var(--transition-base), background var(--transition-base);
  }

  .category-pill:hover { color: var(--color-gold); border-color: var(--color-border-gold); background: var(--color-gold-dim); }

  /* ═══ SERVICES ═══════════════════════════════════ */
  .services-band { background: var(--color-bg); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .services-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.125rem; }

  /* ═══ WHY BET ════════════════════════════════════ */
  .why-inner { display: grid; grid-template-columns: 400px 1fr; gap: 5rem; align-items: center; }

  .why-img-wrap {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 3/4;
    max-height: 580px;
    border: 1px solid var(--color-border);
  }

  .why-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }

  .why-img-badge {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.5rem 1.5rem;
    background: var(--hero-overlay-img-full);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .why-est { font-family: var(--font-display); font-size: 0.6875rem; font-weight: 700; color: var(--color-gold); letter-spacing: 0.12em; text-transform: uppercase; }
  .why-loc { font-family: var(--font-ui); font-size: 0.75rem; color: var(--color-text-muted); }

  .why-content h2 { margin: 0 0 1.375rem; }
  .why-content h2 em { font-style: normal; }

  .why-content :global(.stat-bar-inline) {
    border-top: none;
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
    margin: 1.5rem 0;
  }

  .why-ctas { display: flex; gap: 0.875rem; margin-top: 2rem; flex-wrap: wrap; }

  /* ═══ RIGGING ════════════════════════════════════ */
  .rigging-band { background: var(--color-bg-2); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }

  .rigging-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.125rem; margin-bottom: 1.75rem; }

  .rigging-img-wrap { border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16/10; background: var(--color-bg-card); border: 1px solid var(--color-border); }

  .rigging-img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; display: block; }
  .rigging-img-wrap:hover .rigging-img { transform: scale(1.04); }

  .rigging-proof-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--color-border-gold); border-radius: var(--radius-md); overflow: hidden; }

  .rigging-proof-item { display: flex; flex-direction: column; align-items: flex-start; padding: 1.25rem 1.5rem; border-right: 1px solid var(--color-border-gold); background: var(--color-bg-card); transition: background var(--transition-base); }
  .rigging-proof-item:last-child { border-right: none; }
  .rigging-proof-item:hover { background: var(--color-gold-dim); }

  .rigging-proof-val { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-gold); line-height: 1.2; margin-bottom: 0.25rem; }
  .rigging-proof-detail { font-family: var(--font-ui); font-size: 0.75rem; color: var(--color-text-muted); line-height: 1.4; }

  /* ═══ NATIONAL ═══════════════════════════════════ */
  .national-band { background: var(--color-bg); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: clamp(3rem, 6vw, 5rem) 0; }
  .national-inner { display: grid; grid-template-columns: 1fr 220px; gap: 4rem; align-items: center; }
  .national-h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); margin: 0.4rem 0 1rem; }

  .national-cities { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.25rem; }

  .national-city {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.25rem 0.625rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color var(--transition-base), border-color var(--transition-base), background var(--transition-base);
  }

  .national-city:hover { color: var(--color-gold); border-color: var(--color-border-gold); background: var(--color-gold-dim); }

  .national-circle { width: 180px; height: 180px; border-radius: 50%; border: 1px solid var(--color-border-gold); display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--color-bg-card); margin: 0 auto; }
  .national-circle-num { font-family: var(--font-display); font-size: 3.5rem; font-weight: 800; color: var(--color-gold); line-height: 1; letter-spacing: -0.03em; }
  .national-circle-label { font-family: var(--font-ui); font-size: 0.625rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-subtle); margin-top: 0.25rem; }

  /* ═══ FINAL CTA ══════════════════════════════════ */
  .final-cta-section { border-top: 1px solid var(--color-border); }
  .final-cta { text-align: center; max-width: 560px; margin-left: auto; margin-right: auto; }
  .final-cta h2 { margin: 0.3rem 0 0.875rem; }
  .final-cta p { max-width: 46ch; margin-left: auto; margin-right: auto; margin-bottom: 2rem; }
  .final-cta-actions { display: flex; align-items: center; justify-content: center; gap: 0.875rem; flex-wrap: wrap; }

  .eyebrow-center { justify-content: center; }
  .eyebrow-center::before { display: none; }

  /* ═══ RESPONSIVE ═════════════════════════════════ */
  @media (max-width: 1100px) {
    .hero-inner    { grid-template-columns: 1fr; }
    .why-inner     { grid-template-columns: 1fr; gap: 3rem; }
    .why-img-wrap  { aspect-ratio: 16/9; max-height: 320px; }
    .services-grid { grid-template-columns: repeat(3, 1fr); }
    .rigging-proof-strip { grid-template-columns: repeat(2, 1fr); }
    .rigging-proof-item:nth-child(2) { border-right: none; }
    .rigging-proof-item:nth-child(1),
    .rigging-proof-item:nth-child(2) { border-bottom: 1px solid var(--color-border-gold); }
  }

  @media (max-width: 900px) {
    .services-grid  { grid-template-columns: repeat(2, 1fr); }
    .rigging-grid   { grid-template-columns: 1fr 1fr; }
    .national-inner { grid-template-columns: 1fr; }
    .national-circle { display: none; }
  }

  @media (max-width: 640px) {
    .cards-grid-3  { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .rigging-grid  { grid-template-columns: 1fr; }
    .rigging-proof-strip { grid-template-columns: 1fr 1fr; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .hero-stats { flex-wrap: wrap; gap: 1rem; }
    .hero-stat-div { display: none; }
    .hero-ctas { flex-direction: column; align-items: flex-start; }
    .final-cta-actions { flex-direction: column; }
  }

  .hide-mobile { display: block; }
  @media (max-width: 640px) { .hide-mobile { display: none; } }
</style>

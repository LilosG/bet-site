---
/**
 * Local Service Area Pages — /locations/local/[slug]
 * Hero image via import.meta.glob + getImage — same pattern as equipment/[slug].astro
 */
import { getImage } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../../components/ui/CtaStrip.astro';
import TrustBar from '../../../components/ui/TrustBar.astro';
import StatBar from '../../../components/ui/StatBar.astro';
import { LOCAL_LOCATIONS } from '../../../data/locations';
import { NAP } from '../../../data/site';
import { EQUIPMENT_CATEGORIES } from '../../../data/equipment';
import { SERVICES } from '../../../data/services';
import { breadcrumbSchema, localBusinessSchema } from '../../../lib/schema';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../../assets/images/*.webp',
  { eager: true }
);

function getAsset(filename: string | undefined): ImageMetadata | undefined {
  if (!filename) return undefined;
  return allImages[`../../../assets/images/${filename}`]?.default;
}

export async function getStaticPaths() {
  return LOCAL_LOCATIONS.map((loc) => ({
    params: { slug: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;

const heroAsset = getAsset(loc.heroImage);
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1600, height: 900, format: 'webp', quality: 80 })
  : null;

const crumbs = [
  { name: 'Home',          url: '/' },
  { name: 'Service Areas', url: '/locations' },
  { name: loc.city,        url: `/locations/local/${loc.slug}` },
];

const schemas = [
  localBusinessSchema(),
  breadcrumbSchema(crumbs),
];
---

<Layout
  title={loc.metaTitle}
  description={loc.metaDescription}
  canonical={`/locations/local/${loc.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`loc-hero${optimizedHero ? ' loc-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="loc-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container loc-hero-inner">
      <span class="eyebrow">{loc.city}, {loc.stateAbbr} · Local Service Area</span>
      <h1>{loc.h1}</h1>
      <p class="loc-intro">{loc.intro}</p>
      <div class="loc-hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact the Trade Desk
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/equipment" class="btn btn-outline btn-lg">Browse Equipment</a>
      </div>
    </div>
  </section>

  <StatBar />

  <TrustBar />

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="loc-body-band section-y" aria-labelledby="loc-content-heading">
    <div class="container loc-content-inner">
      <div class="prose">
        <h2 id="loc-content-heading">Brewery Equipment Near {loc.city}</h2>
        {loc.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="loc-sidebar">
        <div class="loc-sidebar-card">
          <h3>Visit Our Facility</h3>
          <address class="loc-address" itemscope itemtype="https://schema.org/PostalAddress">
            <span itemprop="streetAddress">{NAP.street}</span><br />
            <span itemprop="addressLocality">{NAP.city}</span>,
            <span itemprop="addressRegion">{NAP.state}</span>
            <span itemprop="postalCode">{NAP.zip}</span>
          </address>
          <p class="loc-hours-note">Mon–Thu: 10AM–4PM · Fri: 10AM–3PM<br />Sat: By Appointment</p>
          <a href={`tel:${NAP.phonePlain}`} class="loc-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {NAP.phone}
          </a>
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=1520+E+Barham+Dr,+San+Marcos,+CA+92078"
            class="btn btn-outline"
            style="width:100%;justify-content:center;margin-top:1rem;"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get Directions
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- ═══ EQUIPMENT CATEGORIES ══════════════════ -->
  <section class="section-y loc-eq-band" aria-labelledby="loc-eq-heading">
    <div class="container">
      <span class="eyebrow">Equipment Available Near {loc.city}</span>
      <h2 id="loc-eq-heading">Browse by Category</h2>
      <div class="loc-cat-grid">
        {EQUIPMENT_CATEGORIES.map((cat) => (
          <a href={`/equipment/${cat.slug}`} class="loc-cat-item">
            <span class="loc-cat-title">{cat.title}</span>
            <span class="loc-cat-link">
              Browse
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════ -->
  <section class="section-y" aria-labelledby="loc-svc-heading">
    <div class="container">
      <span class="eyebrow">Services in {loc.city}</span>
      <h2 id="loc-svc-heading">What We Handle in {loc.state}</h2>
      <div class="loc-svc-grid">
        {SERVICES.map((svc) => (
          <a href={`/services/${svc.slug}`} class="loc-svc-item">
            <p class="loc-svc-title">{svc.title}</p>
            <p class="loc-svc-desc">{svc.intro}</p>
            <span class="loc-svc-link">
              Learn More
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip
    heading={`Ready to source or move equipment in ${loc.city}?`}
    subtext="One call, one quote. Available for in-person inspection at our San Marcos facility."
    primaryLabel="Contact Trade Desk"
    primaryHref="/contact"
    secondaryLabel="Get a Rigging Quote"
    secondaryHref="/contact?type=rigging"
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .loc-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .loc-hero-has-image {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .loc-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .loc-hero-inner { position: relative; z-index: 1; }
  .loc-hero h1    { max-width: 26ch; margin: 0.5rem 0 1rem; }
  .loc-intro      { max-width: 60ch; font-size: 1.0625rem; margin-bottom: 2rem; }
  .loc-hero-ctas  { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ─── Body + Sidebar ─────────────────────────── */
  .loc-body-band { background: var(--color-bg-2); border-bottom: 1px solid var(--color-border); }

  .loc-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .loc-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-card-rest);
  }

  .loc-sidebar-card h3 { font-size: 1.0625rem; color: var(--color-heading); margin: 0 0 0.75rem; }

  .loc-address {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .loc-hours-note { font-size: 0.8125rem; color: var(--color-text-subtle); margin-bottom: 1rem; line-height: 1.6; }

  .loc-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .loc-phone:hover { color: var(--color-gold-light); }

  /* ─── Equipment grid ─────────────────────────── */
  .loc-eq-band {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .loc-eq-band h2 { margin: 0.4rem 0 0; }

  .loc-cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-top: 1.5rem;
  }

  .loc-cat-item {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    border-right: 1px solid var(--color-border-gold);
    border-bottom: 1px solid var(--color-border-gold);
    text-decoration: none;
    background: transparent;
    transition: background var(--transition-base);
  }

  .loc-cat-item:nth-child(4n)        { border-right: none; }
  .loc-cat-item:nth-last-child(-n+4) { border-bottom: none; }
  .loc-cat-item:hover                { background: var(--color-gold-dim); }

  .loc-cat-title {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-heading);
    display: block;
    margin-bottom: 0.75rem;
    transition: color var(--transition-base);
  }

  .loc-cat-item:hover .loc-cat-title { color: var(--color-gold); }

  .loc-cat-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: gap var(--transition-base);
  }

  .loc-cat-item:hover .loc-cat-link { gap: 0.45rem; }

  /* ─── Services grid ──────────────────────────── */
  .loc-svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 1.5rem; }

  .loc-svc-item {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .loc-svc-item:hover { border-color: var(--color-border-gold); transform: translateY(-2px); }

  .loc-svc-title { font-family: var(--font-ui); font-size: 1rem; font-weight: 600; color: var(--color-heading); margin: 0 0 0.5rem; transition: color var(--transition-base); }
  .loc-svc-item:hover .loc-svc-title { color: var(--color-gold); }
  .loc-svc-desc  { font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 1rem; line-height: 1.6; flex: 1; }

  .loc-svc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: gap var(--transition-base), color var(--transition-base);
    margin-top: auto;
  }

  .loc-svc-item:hover .loc-svc-link { gap: 0.5rem; color: var(--color-gold); }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .loc-content-inner                   { grid-template-columns: 1fr; gap: 2.5rem; }
    .loc-cat-grid                        { grid-template-columns: repeat(2, 1fr); }
    .loc-cat-item:nth-child(4n)          { border-right: 1px solid var(--color-border-gold); }
    .loc-cat-item:nth-child(2n)          { border-right: none; }
    .loc-cat-item:nth-last-child(-n+2)   { border-bottom: none; }
    .loc-svc-grid                        { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .loc-hero-ctas { flex-direction: column; }
    .loc-cat-grid  { grid-template-columns: 1fr 1fr; }
    .loc-svc-grid  { grid-template-columns: 1fr; }
  }
</style>

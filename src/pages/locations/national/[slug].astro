---
/**
 * National Service Area Pages — /locations/national/[slug]
 * Captures out-of-state equipment searches by city.
 */
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../../components/ui/CtaStrip.astro';
import TrustBar from '../../../components/ui/TrustBar.astro';
import { NATIONAL_LOCATIONS } from '../../../data/locations';
import { EQUIPMENT_CATEGORIES } from '../../../data/equipment';
import { breadcrumbSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  return NATIONAL_LOCATIONS.map((loc) => ({
    params: { slug: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;

const crumbs = [
  { name: 'Home',          url: '/' },
  { name: 'Service Areas', url: '/locations' },
  { name: loc.city,        url: `/locations/national/${loc.slug}` },
];

const schemas = [breadcrumbSchema(crumbs)];
---

<Layout
  title={loc.metaTitle}
  description={loc.metaDescription}
  canonical={`/locations/national/${loc.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- Hero -->
  <section class="nat-hero">
    <div class="container">
      <span class="eyebrow">{loc.city}, {loc.stateAbbr} · National Shipping</span>
      <h1>{loc.h1}</h1>
      <p class="nat-intro">{loc.intro}</p>
      <div class="nat-hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact the Trade Desk
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/equipment" class="btn btn-outline btn-lg">Browse Inventory</a>
      </div>
      <div class="nat-ship-note">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Shipping from San Marcos, CA to {loc.city}. Rigging and installation available.
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Body Content -->
  <section class="section-y" aria-labelledby="nat-content-heading">
    <div class="container nat-content-inner">
      <div class="prose">
        <h2 id="nat-content-heading">Used Brewery Equipment Shipped to {loc.city}</h2>
        {loc.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="nat-sidebar">
        <div class="nat-sidebar-card">
          <h3>Ship to {loc.city}</h3>
          <p>We ship anywhere in the US. Bonded freight, crated or pad-wrapped. Rigging at destination available.</p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">
            Request a Shipping Quote
          </a>
          <a href="tel:+19498882739" class="nat-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (949) 888-2739
          </a>
        </div>
        <div class="nat-fact-box">
          <p class="nat-fact-label">Shipping Facts</p>
          <ul>
            <li>Bonded freight to all 50 states</li>
            <li>Crated or pad-wrapped based on equipment</li>
            <li>Crane-in and millwright available</li>
            <li>Single quote covers freight + rigging</li>
            <li>Lead times confirmed at time of purchase</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Equipment grid for this market -->
  <section class="bg-light section-y" aria-labelledby="nat-eq-heading">
    <div class="container">
      <span class="eyebrow">Inventory Available for Shipping to {loc.city}</span>
      <h2 id="nat-eq-heading">Browse Equipment by Category</h2>
      <div class="nat-cat-grid">
        {EQUIPMENT_CATEGORIES.map((cat) => (
          <a href={`/equipment/${cat.slug}`} class="nat-cat-item">
            <span class="nat-cat-name">{cat.title}</span>
            <span class="nat-cat-desc">{cat.description.slice(0, 80)}…</span>
            <span class="nat-cat-cta">
              Browse {cat.title}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip
    heading={`Sourcing equipment in ${loc.city}?`}
    subtext="We ship from San Marcos, CA. Every piece is photographed and inspected before it leaves our yard."
    primaryLabel="Request a Quote"
    primaryHref="/contact"
    secondaryLabel="View Full Inventory"
    secondaryHref="https://beverageequipmenttraders.com/collections/all"
  />
</Layout>

<style>
  .nat-hero {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .nat-hero h1 {
    max-width: 26ch;
    margin: 0.5rem 0 1rem;
  }

  .nat-intro {
    max-width: 60ch;
    font-size: 1.0625rem;
    margin-bottom: 2rem;
  }

  .nat-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .nat-ship-note {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .nat-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .nat-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .nat-sidebar-card h3 {
    font-size: 1.0625rem;
    color: var(--color-white);
    margin: 0 0 0.5rem;
  }

  .nat-sidebar-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .nat-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .nat-phone:hover { color: var(--color-gold-light); }

  .nat-fact-box {
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
  }

  .nat-fact-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .nat-fact-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nat-fact-box li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .nat-fact-box li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: 0.75rem;
  }

  /* Category grid */
  .nat-cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .nat-cat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: white;
    border: 1px solid #e5e0d8;
    border-radius: 4px;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .nat-cat-item:hover {
    border-color: var(--color-teal);
    box-shadow: 0 2px 12px rgba(13,148,136,0.1);
  }

  .nat-cat-name {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #0B0C0F;
  }

  .nat-cat-desc {
    font-size: 0.8125rem;
    color: #6B7280;
    line-height: 1.5;
    flex: 1;
  }

  .nat-cat-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
  }

  @media (max-width: 1024px) {
    .nat-content-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .nat-cat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .nat-hero-ctas { flex-direction: column; }
    .nat-cat-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

---
/**
 * National Service Area Pages — /locations/national/[slug]
 * Hero image via import.meta.glob + getImage — same pattern as equipment/[slug].astro
 */
import { getImage } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaStrip from '../../../components/ui/CtaStrip.astro';
import TrustBar from '../../../components/ui/TrustBar.astro';
import StatBar from '../../../components/ui/StatBar.astro';
import { NATIONAL_LOCATIONS } from '../../../data/locations';
import { EQUIPMENT_CATEGORIES } from '../../../data/equipment';
import { SERVICES } from '../../../data/services';
import { breadcrumbSchema, localBusinessSchema } from '../../../lib/schema';
import { cms, interpolate } from '../../../lib/cms';
import { resolveCmsImage } from '../../../lib/images';

export async function getStaticPaths() {
  return NATIONAL_LOCATIONS.map((loc) => ({
    params: { slug: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;

const heroAsset = resolveCmsImage(loc.heroImage);
const labels = loc.labels;
const labelValues = { city: loc.city, state: loc.state, stateAbbr: loc.stateAbbr };
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1600, height: 900, format: 'webp', quality: 80 })
  : null;

const crumbs = [
  { name: cms.globalCtas.breadcrumbHomeLabel, url: '/' },
  { name: cms.pages.locations.breadcrumbLabel, url: '/locations' },
  { name: loc.city,        url: `/locations/national/${loc.slug}` },
];

const schemas = [
  localBusinessSchema(),
  breadcrumbSchema(crumbs),
];
---

<Layout
  title={loc.metaTitle}
  description={loc.metaDescription}
  canonical={`/locations/national/${loc.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`nat-hero${optimizedHero ? ' nat-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="nat-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container nat-hero-inner">
      <span class="eyebrow">{interpolate(labels.heroEyebrow, labelValues)}</span>
      <h1>{loc.h1}</h1>
      <p class="nat-intro">{loc.intro}</p>
      <div class="nat-hero-ctas">
        <a href={labels.primaryCta.href} class="btn btn-primary btn-lg">
          {labels.primaryCta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={labels.secondaryCta.href} class="btn btn-outline btn-lg">{labels.secondaryCta.label}</a>
      </div>
      <div class="nat-ship-note">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        {interpolate(labels.shippingNote, labelValues)}
      </div>
    </div>
  </section>

  <StatBar />

  <TrustBar />

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="nat-body-band section-y" aria-labelledby="nat-content-heading">
    <div class="container nat-content-inner">
      <div class="prose">
        <h2 id="nat-content-heading">{interpolate(labels.bodyHeading, labelValues)}</h2>
        {loc.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="nat-sidebar">
        <div class="nat-sidebar-card">
          <h3>{interpolate(labels.sidebarHeading, labelValues)}</h3>
          <p>{labels.sidebarBody}</p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">
            {labels.sidebarCtaLabel}
          </a>
          <a href={`tel:${cms.company.nap.phonePlain}`} class="nat-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {cms.company.nap.phone}
          </a>
        </div>
        <div class="nat-fact-box">
          <p class="nat-fact-label">{labels.factsLabel}</p>
          <ul>
            {labels.facts.map(fact => <li>{fact}</li>)}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- ═══ EQUIPMENT CATEGORIES ══════════════════ -->
  <section class="section-y nat-eq-band" aria-labelledby="nat-eq-heading">
    <div class="container">
      <span class="eyebrow">{interpolate(labels.equipmentEyebrow, labelValues)}</span>
      <h2 id="nat-eq-heading">{labels.equipmentHeading}</h2>
      <div class="nat-cat-grid">
        {EQUIPMENT_CATEGORIES.map((cat) => (
          <a href={`/equipment/${cat.slug}/${loc.slug}`} class="nat-cat-item">
            <span class="nat-cat-name">{cat.title}</span>
            <span class="nat-cat-desc">{cat.description}</span>
            <span class="nat-cat-cta">
              {labels.equipmentCtaPrefix} {cat.title}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════ -->
  <section class="section-y" aria-labelledby="nat-svc-heading">
    <div class="container">
      <span class="eyebrow">{interpolate(labels.servicesEyebrow, labelValues)}</span>
      <h2 id="nat-svc-heading">{labels.servicesHeading}</h2>
      <div class="nat-svc-grid">
        {SERVICES.map((svc) => (
          <a href={`/services/${svc.slug}/${loc.slug}`} class="nat-svc-item">
            <p class="nat-svc-title">{svc.title}</p>
            <p class="nat-svc-desc">{svc.intro}</p>
            <span class="nat-svc-link">
              {labels.servicesCtaLabel}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip
    heading={interpolate(labels.finalCtaHeading, labelValues)}
    subtext={labels.finalCtaBody}
    primaryLabel={labels.finalPrimaryCta.label}
    primaryHref={labels.finalPrimaryCta.href}
    secondaryLabel={labels.finalSecondaryCta.label}
    secondaryHref={labels.finalSecondaryCta.href}
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .nat-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .nat-hero-has-image {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .nat-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .nat-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .nat-hero-inner { position: relative; z-index: 1; }
  .nat-hero h1    { max-width: 26ch; margin: 0.5rem 0 1rem; }
  .nat-intro      { max-width: 60ch; font-size: 1.0625rem; margin-bottom: 2rem; }

  .nat-hero-ctas  { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }

  .nat-ship-note {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* ─── Body + Sidebar ─────────────────────────── */
  .nat-body-band { background: var(--color-bg-2); border-bottom: 1px solid var(--color-border); }

  .nat-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .nat-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-card-rest);
  }

  .nat-sidebar-card h3 { font-size: 1.0625rem; color: var(--color-heading); margin: 0 0 0.5rem; }
  .nat-sidebar-card p  { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1.25rem; }

  .nat-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .nat-phone:hover { color: var(--color-gold-light); }

  .nat-fact-box {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-card-rest);
  }

  .nat-fact-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .nat-fact-box ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }

  .nat-fact-box li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .nat-fact-box li::before { content: '—'; position: absolute; left: 0; color: var(--color-gold); font-size: 0.75rem; }

  /* ─── Equipment grid ─────────────────────────── */
  .nat-eq-band {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .nat-eq-band h2 { margin: 0.4rem 0 0; }

  .nat-cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1.5rem; }

  .nat-cat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .nat-cat-item:hover { border-color: var(--color-border-gold); transform: translateY(-2px); }

  .nat-cat-name { font-family: var(--font-ui); font-size: 0.9375rem; font-weight: 700; color: var(--color-heading); transition: color var(--transition-base); }
  .nat-cat-item:hover .nat-cat-name { color: var(--color-gold); }
  .nat-cat-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .nat-cat-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: 0.25rem;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .nat-cat-item:hover .nat-cat-cta { gap: 0.45rem; color: var(--color-gold); }

  /* ─── Services grid ──────────────────────────── */
  .nat-svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 1.5rem; }

  .nat-svc-item {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .nat-svc-item:hover { border-color: var(--color-border-gold); transform: translateY(-2px); }

  .nat-svc-title { font-family: var(--font-ui); font-size: 1rem; font-weight: 600; color: var(--color-heading); margin: 0 0 0.5rem; transition: color var(--transition-base); }
  .nat-svc-item:hover .nat-svc-title { color: var(--color-gold); }
  .nat-svc-desc  { font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 1rem; line-height: 1.6; flex: 1; }

  .nat-svc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: gap var(--transition-base), color var(--transition-base);
    margin-top: auto;
  }

  .nat-svc-item:hover .nat-svc-link { gap: 0.5rem; color: var(--color-gold); }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .nat-content-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .nat-cat-grid      { grid-template-columns: repeat(2, 1fr); }
    .nat-svc-grid      { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .nat-hero-ctas { flex-direction: column; }
    .nat-cat-grid  { grid-template-columns: 1fr 1fr; }
    .nat-svc-grid  { grid-template-columns: 1fr; }
  }
</style>

---
/**
 * Service Page — /services/[slug]
 * Full service page template.
 * All content from central data layer — zero hardcoding.
 * Hero image via import.meta.glob + getImage — same pattern as equipment/[slug].astro
 */
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FAQ from '../../components/ui/FAQ.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import ProcessSteps from '../../components/ui/ProcessSteps.astro';
import BestFitScenarios from '../../components/ui/BestFitScenarios.astro';
import StatBar from '../../components/ui/StatBar.astro';
import TrustBar from '../../components/ui/TrustBar.astro';
import { SERVICES } from '../../data/services';
import { LOCAL_LOCATIONS, NATIONAL_LOCATIONS } from '../../data/locations';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { breadcrumbSchema, faqSchema, serviceSchema } from '../../lib/schema';
import { NAP } from '../../data/site';
import { cms, interpolate } from '../../lib/cms';
import { resolveCmsImage } from '../../lib/images';

export async function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const heroAsset = resolveCmsImage(service.heroImage);
const labels = service.labels;
const labelValues = { title: service.title, shortTitle: service.shortTitle, shortTitleLower: service.shortTitle.toLowerCase() };
const optimizedHero = heroAsset
  ? await getImage({ src: heroAsset, width: 1600, height: 900, format: 'webp', quality: 80 })
  : null;

const related = service.relatedServices
  .map((slug) => SERVICES.find((s) => s.slug === slug))
  .filter((record): record is NonNullable<typeof record> => record !== undefined);

const relatedEquipment = service.relatedEquipment
  .map((slug) => EQUIPMENT_CATEGORIES.find((c) => c.slug === slug))
  .filter((record): record is NonNullable<typeof record> => record !== undefined)
  .slice(0, 4);

const crumbs = [
  { name: cms.globalCtas.breadcrumbHomeLabel, url: '/' },
  { name: cms.pages.services.breadcrumbLabel, url: '/services' },
  { name: service.title, url: `/services/${service.slug}` },
];

const schemas = [
  breadcrumbSchema(crumbs),
  faqSchema(service.faqs),
  serviceSchema({
    name: service.title,
    description: service.intro,
    url: `/services/${service.slug}`,
    keywords: service.keywords,
  }),
];
---

<Layout
  title={service.metaTitle}
  description={service.metaDescription}
  canonical={`/services/${service.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class={`svc-hero${optimizedHero ? ' svc-hero-has-image' : ''}`}>
    {optimizedHero && (
      <div
        class="svc-hero-bg"
        style={`background-image: url('${optimizedHero.src}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container svc-hero-inner">
      <span class="eyebrow">{labels.heroEyebrow}</span>
      <h1>{service.h1}</h1>
      <p class="svc-hero-intro">{service.intro}</p>
      <div class="svc-hero-ctas">
        <a href={service.cta.href} class="btn btn-primary btn-lg">
          {service.cta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`tel:${NAP.phonePlain}`} class="btn btn-outline btn-lg">
          {labels.callPrefix} {NAP.phone}
        </a>
      </div>
      <div class="svc-trust-chips">
        {labels.trustChips.map((chip) => (
          <span class="trust-chip">{chip}</span>
        ))}
      </div>
    </div>
  </section>

  <StatBar />

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="svc-body-band section-y" aria-labelledby="svc-content-heading">
    <div class="container svc-content-inner">
      <div class="prose svc-prose">
        <h2 id="svc-content-heading">{service.title} {labels.bodyHeadingSuffix}</h2>
        {service.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>
      <aside class="svc-sidebar">
        <div class="svc-sidebar-card">
          <h3>{service.cta.label}</h3>
          <p>{labels.sidebarBody}</p>
          <a href={service.cta.href} class="btn btn-primary" style="width:100%;justify-content:center;">
            {service.cta.label}
          </a>
          <a href={`tel:${NAP.phonePlain}`} class="svc-phone-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {NAP.phone}
          </a>
        </div>
        {related.length > 0 && (
          <div class="svc-related">
            <p class="svc-related-label">{labels.relatedServicesLabel}</p>
            <ul>
              {related.map((s) => (
                <li>
                  <a href={`/services/${s.slug}`}>
                    {s.title}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <!-- ═══ PROCESS STEPS ══════════════════════════ -->
  {service.processSteps.length > 0 && (
    <ProcessSteps
      steps={service.processSteps}
      heading={interpolate(labels.processHeading, labelValues)}
      eyebrow={labels.processEyebrow}
    />
  )}

  <TrustBar />

  <!-- ═══ BEST FIT SCENARIOS ═════════════════════ -->
  {service.bestFitScenarios.length > 0 && (
    <BestFitScenarios
      scenarios={service.bestFitScenarios}
      heading={interpolate(labels.bestFitHeading, labelValues)}
      eyebrow={labels.bestFitEyebrow}
      cta={service.cta}
    />
  )}

  <!-- ═══ RELATED EQUIPMENT ══════════════════════ -->
  {relatedEquipment.length > 0 && (
    <section class="svc-related-eq-band section-y" aria-labelledby="related-eq-heading">
      <div class="container">
        <div class="related-eq-header">
          <span class="eyebrow">{labels.relatedEquipmentEyebrow}</span>
          <h2 id="related-eq-heading">{labels.relatedEquipmentHeading}</h2>
        </div>
        <div class="related-eq-grid">
          {relatedEquipment.map((cat) => (
            <a href={`/equipment/${cat.slug}`} class="related-eq-card">
              <div class="related-eq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <path d="M8 21h8M12 17v4"/>
                </svg>
              </div>
              <div class="related-eq-content">
                <h3>{cat.title}</h3>
                <p>{cat.description}</p>
              </div>
              <svg class="related-eq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ SERVICE BY LOCATION ═══════════════════ -->
  <section class="section-y svc-locations-band" aria-labelledby="svc-locations-heading">
    <div class="container">
      <span class="eyebrow">{labels.locationsEyebrow}</span>
      <h2 id="svc-locations-heading">{interpolate(labels.locationsHeading, labelValues)}</h2>
      <p class="svc-locations-intro">{interpolate(labels.locationsBody, labelValues)}</p>
      <div class="svc-locations-grid">
        <div class="svc-locations-col">
          <p class="svc-locations-group-label">{labels.localGroupLabel}</p>
          <ul class="svc-locations-list">
            {LOCAL_LOCATIONS.map((loc) => (
              <li>
                <a href={`/services/${service.slug}/${loc.slug}`} class="svc-location-link">
                  {service.shortTitle} — {loc.city}, {loc.stateAbbr}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="svc-locations-col">
          <p class="svc-locations-group-label">{labels.nationalGroupLabel}</p>
          <ul class="svc-locations-list">
            {NATIONAL_LOCATIONS.map((loc) => (
              <li>
                <a href={`/services/${service.slug}/${loc.slug}`} class="svc-location-link">
                  {service.shortTitle} — {loc.city}, {loc.stateAbbr}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ════════════════════════════════════ -->
  <FAQ
    items={service.faqs}
    heading={interpolate(labels.faqHeading, labelValues)}
  />

  <!-- ═══ FINAL CTA ══════════════════════════════ -->
  <CtaStrip
    heading={labels.finalCtaHeading}
    subtext={labels.finalCtaBody}
    primaryLabel={service.cta.label}
    primaryHref={service.cta.href}
    secondaryLabel={labels.finalSecondaryCta.label}
    secondaryHref={labels.finalSecondaryCta.href}
  />
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .svc-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-hero-has-image {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .svc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    pointer-events: none;
  }

  .svc-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      var(--hero-overlay-right),
      var(--hero-overlay-bottom);
  }

  .svc-hero-inner   { position: relative; z-index: 1; }
  .svc-hero h1      { max-width: 26ch; margin: 0.5rem 0 1rem; color: var(--color-white); }
  .svc-hero-intro   { max-width: 60ch; font-size: 1.0625rem; margin-bottom: 2rem; color: rgba(255,255,255,0.85); }

  .svc-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .svc-trust-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .trust-chip {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
  }

  /* ─── Body + Sidebar ─────────────────────────── */
  .svc-body-band {
    background: var(--color-bg-2);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .svc-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-card-rest);
  }

  .svc-sidebar-card h3 { font-size: 1.0625rem; color: var(--color-heading); margin: 0 0 0.5rem; }
  .svc-sidebar-card p  { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1.25rem; }

  .svc-phone-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .svc-phone-link:hover { color: var(--color-gold-light); }

  .svc-related {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-card-rest);
  }

  .svc-related-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .svc-related ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }

  .svc-related a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0;
    transition: color var(--transition-base);
  }

  .svc-related a:hover { color: var(--color-teal); }

  /* ─── Related Equipment ──────────────────────── */
  .svc-related-eq-band {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .related-eq-header        { margin-bottom: 1.75rem; }
  .related-eq-header h2     { margin: 0.3rem 0 0; }

  .related-eq-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .related-eq-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    box-shadow: var(--shadow-card-rest);
    transition: border-color var(--transition-smooth), transform var(--transition-smooth), box-shadow var(--transition-smooth);
  }

  .related-eq-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
  }

  .related-eq-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 3px;
    background: var(--color-teal-dim);
    color: var(--color-teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .related-eq-content       { flex: 1; min-width: 0; }

  .related-eq-content h3 {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.25rem;
    line-height: 1.3;
    transition: color var(--transition-base);
  }

  .related-eq-card:hover .related-eq-content h3 { color: var(--color-gold); }

  .related-eq-content p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-eq-arrow {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    margin-top: 0.25rem;
    transition: color var(--transition-base), transform var(--transition-base);
  }

  .related-eq-card:hover .related-eq-arrow {
    color: var(--color-gold);
    transform: translateX(2px);
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .svc-content-inner    { grid-template-columns: 1fr; gap: 2.5rem; }
    .svc-sidebar          { display: flex; gap: 1.25rem; flex-wrap: wrap; }
    .svc-sidebar-card,
    .svc-related          { flex: 1; min-width: 240px; }
    .related-eq-grid      { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .svc-hero-ctas   { flex-direction: column; }
    .related-eq-grid { grid-template-columns: 1fr; }
  }

  /* ─── Location links ─────────────────────────── */
  .svc-locations-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-locations-band h2 { margin: 0.4rem 0 0.5rem; }

  .svc-locations-intro {
    max-width: 60ch;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .svc-locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .svc-locations-group-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.875rem;
  }

  .svc-locations-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .svc-location-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base), padding-left var(--transition-base);
  }

  .svc-location-link:hover {
    color: var(--color-teal);
    padding-left: 0.25rem;
  }

  @media (max-width: 640px) {
    .svc-locations-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

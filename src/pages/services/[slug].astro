---
/**
 * Service Page — /services/[slug]
 * Full service page template.
 * All content from central data layer — zero hardcoding.
 * Sections: Hero → Body+Sidebar → Process → Best Fit → Related Equipment → FAQ → CTA
 */
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FAQ from '../../components/ui/FAQ.astro';
import CtaStrip from '../../components/ui/CtaStrip.astro';
import ProcessSteps from '../../components/ui/ProcessSteps.astro';
import BestFitScenarios from '../../components/ui/BestFitScenarios.astro';
import { SERVICES } from '../../data/services';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { breadcrumbSchema, faqSchema, serviceSchema } from '../../lib/schema';
import { NAP } from '../../data/site';

export async function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const related = service.relatedServices
  .map((slug) => SERVICES.find((s) => s.slug === slug))
  .filter(Boolean);

const relatedEquipment = service.relatedEquipment
  .map((slug) => EQUIPMENT_CATEGORIES.find((c) => c.slug === slug))
  .filter(Boolean)
  .slice(0, 4);

const crumbs = [
  { name: 'Home',        url: '/' },
  { name: 'Services',    url: '/services' },
  { name: service.title, url: `/services/${service.slug}` },
];

const schemas = [
  breadcrumbSchema(crumbs),
  faqSchema(service.faqs),
  serviceSchema({
    name: service.title,
    description: service.intro,
    url: `/services/${service.slug}`,
    keywords: service.keywords,
  }),
];
---

<Layout
  title={service.metaTitle}
  description={service.metaDescription}
  canonical={`/services/${service.slug}`}
  schemas={schemas}
>
  <Breadcrumb crumbs={crumbs} />

  <!-- ═══ HERO ══════════════════════════════════ -->
  <section class="svc-hero">
    <div class="container">
      <span class="eyebrow">Service</span>
      <h1>{service.h1}</h1>
      <p class="svc-hero-intro">{service.intro}</p>
      <div class="svc-hero-ctas">
        <a href={service.cta.href} class="btn btn-primary btn-lg">
          {service.cta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`tel:${NAP.phonePlain}`} class="btn btn-outline btn-lg">
          Call {NAP.phone}
        </a>
      </div>
      <div class="svc-trust-chips">
        {['All 50 States', 'One Quote — Full Scope', 'Prior Brewery Operators', 'San Marcos, CA'].map((chip) => (
          <span class="trust-chip">{chip}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BODY CONTENT + SIDEBAR ════════════════ -->
  <section class="svc-body-band section-y" aria-labelledby="svc-content-heading">
    <div class="container svc-content-inner">

      <div class="prose svc-prose">
        <h2 id="svc-content-heading">{service.title} — What to Know</h2>
        {service.bodyContent.split('\n\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
      </div>

      <aside class="svc-sidebar">
        <div class="svc-sidebar-card">
          <h3>{service.cta.label}</h3>
          <p>Our trade desk responds within one business day. Provide details and we will return a complete scope and price.</p>
          <a href={service.cta.href} class="btn btn-primary" style="width:100%;justify-content:center;">
            {service.cta.label}
          </a>
          <a href={`tel:${NAP.phonePlain}`} class="svc-phone-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {NAP.phone}
          </a>
        </div>

        {related.length > 0 && (
          <div class="svc-related">
            <p class="svc-related-label">Other Services</p>
            <ul>
              {related.map((s) => (
                <li>
                  <a href={`/services/${s.slug}`}>
                    {s.title}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>

    </div>
  </section>

  <!-- ═══ PROCESS STEPS ══════════════════════════ -->
  {service.processSteps.length > 0 && (
    <ProcessSteps
      steps={service.processSteps}
      heading={`How ${service.shortTitle} Works`}
      eyebrow="The Process"
    />
  )}

  <!-- ═══ BEST FIT SCENARIOS ═════════════════════ -->
  {service.bestFitScenarios.length > 0 && (
    <BestFitScenarios
      scenarios={service.bestFitScenarios}
      heading={`When ${service.shortTitle} Is the Right Choice`}
      eyebrow="Best Fit"
      cta={service.cta}
    />
  )}

  <!-- ═══ RELATED EQUIPMENT ══════════════════════ -->
  {relatedEquipment.length > 0 && (
    <section class="svc-related-eq-band section-y" aria-labelledby="related-eq-heading">
      <div class="container">
        <div class="related-eq-header">
          <span class="eyebrow">Related Equipment</span>
          <h2 id="related-eq-heading">Equipment We Work With</h2>
        </div>
        <div class="related-eq-grid">
          {relatedEquipment.map((cat) => (
            <a href={`/equipment/${cat.slug}`} class="related-eq-card">
              <div class="related-eq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <path d="M8 21h8M12 17v4"/>
                </svg>
              </div>
              <div class="related-eq-content">
                <h3>{cat.title}</h3>
                <p>{cat.description}</p>
              </div>
              <svg class="related-eq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FAQ ════════════════════════════════════ -->
  <FAQ
    items={service.faqs}
    heading={`${service.title} — Frequently Asked Questions`}
  />

  <!-- ═══ FINAL CTA ══════════════════════════════ -->
  <CtaStrip
    heading="Ready to get started?"
    subtext="One call, one quote. Our trade desk handles everything from scope to scheduling."
    primaryLabel={service.cta.label}
    primaryHref={service.cta.href}
    secondaryLabel="Browse Equipment"
    secondaryHref="/equipment"
  />

</Layout>

<style>
  /* ─── Hero ───────────────────────────────────── */
  .svc-hero {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-hero h1 {
    max-width: 26ch;
    margin: 0.5rem 0 1rem;
  }

  .svc-hero-intro {
    max-width: 60ch;
    font-size: 1.0625rem;
    margin-bottom: 2rem;
  }

  .svc-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .svc-trust-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .trust-chip {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
  }

  /* ─── Body + Sidebar ─────────────────────────── */
  .svc-body-band {
    background: var(--color-bg-2);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-content-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .svc-sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-gold);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .svc-sidebar-card h3 {
    font-size: 1.0625rem;
    color: var(--color-white);
    margin: 0 0 0.5rem;
  }

  .svc-sidebar-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .svc-phone-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    margin-top: 1rem;
    transition: color var(--transition-base);
  }

  .svc-phone-link:hover { color: var(--color-gold-light); }

  .svc-related {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }

  .svc-related-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.75rem;
  }

  .svc-related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .svc-related a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0;
    transition: color var(--transition-base);
  }

  .svc-related a:hover { color: var(--color-teal); }

  /* ─── Related Equipment ──────────────────────── */
  .svc-related-eq-band {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .related-eq-header {
    margin-bottom: 1.75rem;
  }

  .related-eq-header h2 {
    margin: 0.3rem 0 0;
  }

  .related-eq-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .related-eq-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .related-eq-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-1px);
  }

  .related-eq-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 3px;
    background: var(--color-teal-dim);
    color: var(--color-teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .related-eq-content {
    flex: 1;
    min-width: 0;
  }

  .related-eq-content h3 {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.25rem;
    line-height: 1.3;
    transition: color var(--transition-base);
  }

  .related-eq-card:hover .related-eq-content h3 {
    color: var(--color-gold);
  }

  .related-eq-content p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-eq-arrow {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    margin-top: 0.25rem;
    transition: color var(--transition-base), transform var(--transition-base);
  }

  .related-eq-card:hover .related-eq-arrow {
    color: var(--color-gold);
    transform: translateX(2px);
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .svc-content-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .svc-sidebar {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .svc-sidebar-card,
    .svc-related {
      flex: 1;
      min-width: 240px;
    }
    .related-eq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .svc-hero-ctas { flex-direction: column; }
    .related-eq-grid { grid-template-columns: 1fr; }
  }
</style>

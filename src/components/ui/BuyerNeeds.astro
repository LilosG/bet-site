---
/**
 * BuyerNeeds.astro
 * Renders "what this industry typically sources" cards.
 * Used on all industry detail pages.
 * All content passed via props — zero hardcoding.
 * Distinct from BestFitScenarios — no icon required.
 */
export interface Need {
  title: string;
  description: string;
}

export interface Props {
  needs: Need[];
  heading?: string;
  eyebrow?: string;
}

const {
  needs,
  heading = 'What Operations Typically Source',
  eyebrow = 'Common Needs',
} = Astro.props;
---

<section class="needs-section section-y" aria-labelledby="needs-heading">
  <div class="container">
    <div class="needs-header">
      <span class="eyebrow">{eyebrow}</span>
      <h2 id="needs-heading">{heading}</h2>
    </div>
    <div class="needs-grid">
      {needs.map((need) => (
        <div class="need-card">
          <h3 class="need-title">{need.title}</h3>
          <p class="need-desc">{need.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .needs-section {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .needs-header {
    margin-bottom: 2rem;
  }

  .needs-header h2 {
    margin: 0.3rem 0 0;
  }

  .needs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.125rem;
    counter-reset: need-counter;
  }

  .need-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    position: relative;
    counter-increment: need-counter;
    transition: border-color var(--transition-smooth), border-top-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .need-card::before {
    content: counter(need-counter, decimal-leading-zero);
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 800;
    color: var(--color-text-subtle);
    letter-spacing: 0.08em;
  }

  .need-card:hover {
    border-color: var(--color-border-gold);
    border-top-color: var(--color-gold);
    transform: translateY(-2px);
  }

  .need-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.625rem;
    line-height: 1.3;
  }

  .need-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .needs-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .needs-grid { grid-template-columns: 1fr; }
  }
</style>

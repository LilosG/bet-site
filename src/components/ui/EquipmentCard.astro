---
/**
 * EquipmentCard — Reusable card for equipment items.
 * Uses astro:assets Image component for optimized images.
 * Falls back to placeholder when no image provided.
 * All colors use design tokens — zero hardcoding.
 */
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  price: string;
  condition: 'Used' | 'New' | 'Refurbished';
  category: string;
  image?: ImageMetadata;
  href?: string;
  sku?: string;
}

const {
  name,
  price,
  condition,
  category,
  image,
  href = 'https://beverageequipmenttraders.com/collections/all',
  sku,
} = Astro.props;

const conditionClass = {
  Used:        'tag-used',
  New:         'tag-new',
  Refurbished: 'tag-refurb',
}[condition] ?? 'tag-used';
---

<article class="equipment-card card">
  <div class="card-image-wrap">
    {image ? (
      <Image
        src={image}
        alt={`${name} — ${condition} ${category}`}
        class="card-image"
        width={480}
        height={320}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-image-placeholder" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8M12 17v4"/>
        </svg>
      </div>
    )}
    <span class={`card-condition-badge ${conditionClass}`}>{condition}</span>
  </div>

  <div class="card-body">
    <div class="card-category tag tag-gold">{category}</div>
    <h3 class="card-title">{name}</h3>
    {sku && <p class="card-sku">SKU: {sku}</p>}

    <div class="card-footer">
      <span class="card-price">{price}</span>
      <a
        href={href}
        class="card-cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`View details for ${name}`}
      >
        View Details
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .equipment-card { display: flex; flex-direction: column; }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--color-bg-2);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
    display: block;
  }

  .equipment-card:hover .card-image { transform: scale(1.03); }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
  }

  .card-condition-badge {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    font-family: var(--font-ui);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }

  .tag-used   { background: rgba(11,12,15,0.85); color: var(--color-text-muted); border: 1px solid var(--color-border); }
  .tag-new    { background: rgba(13,148,136,0.85); color: var(--color-white); }
  .tag-refurb { background: rgba(201,150,58,0.85); color: var(--color-white); }

  .card-body {
    padding: 1rem 1.125rem 1.125rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-category { margin-bottom: 0.5rem; font-size: 0.5625rem; letter-spacing: 0.1em; }

  .card-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .card-sku {
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    margin: 0 0 0.75rem;
    font-family: var(--font-ui);
    letter-spacing: 0.03em;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border);
  }

  .card-price {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-gold);
    letter-spacing: -0.02em;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    text-decoration: none;
    transition: color var(--transition-base), gap var(--transition-base);
  }

  .card-cta:hover { color: var(--color-gold); gap: 0.45rem; }
</style>

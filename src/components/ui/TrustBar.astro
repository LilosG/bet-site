---
import { Image } from 'astro:assets';
import { cms } from '../../lib/cms';
import { resolveCmsImage } from '../../lib/images';

export interface Props {
  heading?: string;
  light?: boolean;
}

const { heading = cms.trustProof.heading, light = false } = Astro.props;
const clients = (Array.isArray(cms.trustProof.clients) ? cms.trustProof.clients : [])
  .flatMap(client => {
    const imageAsset = resolveCmsImage(client.image);
    return imageAsset ? [{ ...client, imageAsset }] : [];
  });
---

<div class={`trust-bar${light ? ' trust-bar-light' : ''}`} aria-label={heading}>
  <div class="container trust-bar-inner">
    <p class="trust-bar-label">{heading}</p>
    <ul class="trust-bar-logos" role="list" aria-label={cms.trustProof.rosterAriaLabel}>
      {clients.map((client) => (
        <li class="trust-logo-item">
          <Image
            src={client.imageAsset}
            alt={client.imageAlt}
            class="trust-logo-img"
            height={32}
            width={120}
            loading="lazy"
            decoding="async"
          />
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .trust-bar-light { background: var(--color-bg-light-2); border-color: rgba(0,0,0,0.08); }
  .trust-bar-inner { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; }
  .trust-bar-label { font-family: var(--font-ui); font-size: 0.625rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-subtle); white-space: nowrap; margin: 0; flex-shrink: 0; }
  .trust-bar-light .trust-bar-label { color: var(--color-text-muted); }
  .trust-bar-logos { display: flex; align-items: center; gap: 2.5rem; list-style: none; margin: 0; padding: 0; flex-wrap: wrap; }
  .trust-logo-item { flex-shrink: 0; }
  .trust-logo-img { height: 28px; width: auto; object-fit: contain; display: block; filter: invert(1) brightness(1) opacity(0.45); transition: opacity var(--transition-base), filter var(--transition-base); }
  .trust-logo-item:hover .trust-logo-img { filter: invert(1) brightness(1) opacity(0.75); }
  .trust-bar-light .trust-logo-img { filter: brightness(0) opacity(0.35); }
  .trust-bar-light .trust-logo-item:hover .trust-logo-img { filter: brightness(0) opacity(0.6); }
  @media (max-width: 768px) {
    .trust-bar-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .trust-bar-logos { gap: 1.5rem; }
    .trust-logo-img { height: 24px; }
  }
</style>

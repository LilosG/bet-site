---
/**
 * TrustBar — Horizontal client logo strip.
 * Used on homepage and key landing pages.
 */
import { CLIENTS } from '../../data/site';

export interface Props {
  heading?: string;
  light?: boolean;
}

const { heading = 'Trusted by leading craft producers', light = false } = Astro.props;
---

<div class={`trust-bar ${light ? 'trust-bar--light' : ''}`} aria-label={heading}>
  <div class="container trust-bar-inner">
    <p class="trust-bar-label">{heading}</p>
    <ul class="trust-bar-logos" role="list" aria-label="Client roster">
      {CLIENTS.map((client) => (
        <li class="trust-logo-item">
          <span class="trust-logo-name">{client}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .trust-bar--light {
    background: var(--color-bg-light-2);
    border-color: rgba(0,0,0,0.08);
  }

  .trust-bar-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .trust-bar-label {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    white-space: nowrap;
    margin: 0;
    flex-shrink: 0;
  }

  .trust-bar--light .trust-bar-label {
    color: #6B7280;
  }

  .trust-bar-logos {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .trust-logo-item {
    flex-shrink: 0;
  }

  .trust-logo-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color var(--transition-base);
  }

  .trust-bar--light .trust-logo-name {
    color: #9CA3AF;
  }

  .trust-logo-item:hover .trust-logo-name {
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .trust-bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .trust-bar-logos {
      gap: 1.5rem;
    }
  }
</style>

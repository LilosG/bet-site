---
/**
 * BestFitScenarios.astro
 * Use case cards for service pages.
 * All content passed via props — zero hardcoding.
 * Default: dark context. Pass light={true} for light sections.
 */
export interface Scenario {
  title: string;
  description: string;
  icon: string;
}

export interface Props {
  scenarios: Scenario[];
  heading?: string;
  eyebrow?: string;
  cta?: { label: string; href: string };
  light?: boolean;
}

const {
  scenarios,
  heading = 'Is This Right for You?',
  eyebrow = 'Best Fit',
  cta,
  light = false,
} = Astro.props;
---

<section
  class={`scenarios-section section-y${light ? ' scenarios-light' : ' scenarios-dark'}`}
  aria-labelledby="scenarios-heading"
>
  <div class="container">
    <div class="scenarios-header">
      <div>
        <span class="eyebrow">{eyebrow}</span>
        <h2 id="scenarios-heading">{heading}</h2>
      </div>
      {cta && (
        <a href={cta.href} class="btn btn-outline scenarios-header-cta">
          {cta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </div>

    <div class="scenarios-grid">
      {scenarios.map((scenario) => (
        <div class="scenario-card">
          <div class="scenario-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={scenario.icon} />
            </svg>
          </div>
          <h3 class="scenario-title">{scenario.title}</h3>
          <p class="scenario-desc">{scenario.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ─── Section backgrounds ────────────────────── */
  .scenarios-dark {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .scenarios-light {
    background: var(--color-bg-light);
    border-top: 1px solid rgba(0,0,0,0.06);
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  /* ─── Header ─────────────────────────────────── */
  .scenarios-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .scenarios-header h2 {
    margin: 0.3rem 0 0;
  }

  .scenarios-light .scenarios-header h2 {
    color: var(--color-bg);
  }

  .scenarios-light .eyebrow {
    color: var(--color-teal);
  }

  .scenarios-light .eyebrow::before {
    background: var(--color-teal);
  }

  .scenarios-header-cta {
    flex-shrink: 0;
  }

  .scenarios-dark .scenarios-header-cta {
    color: var(--color-heading);
    border-color: var(--color-border-subtle);
  }

  .scenarios-dark .scenarios-header-cta:hover {
    color: var(--color-gold);
    border-color: var(--color-border-gold);
    background: var(--color-bg-overlay);
  }

  /* ─── Cards ──────────────────────────────────── */
  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.125rem;
  }

  .scenario-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-card-rest);
    transition: border-color var(--transition-smooth), transform var(--transition-smooth), box-shadow var(--transition-smooth);
  }

  .scenario-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .scenarios-light .scenario-card {
    background: var(--color-white);
    border-color: rgba(0,0,0,0.08);
  }

  .scenarios-light .scenario-card:hover {
    border-color: var(--color-teal);
  }

  /* ─── Icon ───────────────────────────────────── */
  .scenario-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 3px;
    background: var(--color-gold-dim);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    flex-shrink: 0;
    transition: background var(--transition-smooth);
  }

  .scenario-card:hover .scenario-icon {
    background: var(--color-teal-dim);
    color: var(--color-teal);
  }

  .scenarios-light .scenario-icon {
    background: var(--color-teal-dim);
    color: var(--color-teal);
  }

  /* ─── Text ───────────────────────────────────── */
  .scenario-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.625rem;
    line-height: 1.25;
    transition: color var(--transition-base);
  }

  .scenario-card:hover .scenario-title {
    color: var(--color-gold);
  }

  .scenarios-light .scenario-title {
    color: var(--color-bg);
  }

  .scenarios-light .scenario-card:hover .scenario-title {
    color: var(--color-teal);
  }

  .scenario-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .scenarios-light .scenario-desc {
    color: var(--color-text-muted);
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .scenarios-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .scenarios-grid { grid-template-columns: 1fr; }
    .scenarios-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

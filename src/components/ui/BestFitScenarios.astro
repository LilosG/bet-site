---
/**
 * BestFitScenarios.astro
 * Renders "Is this right for me?" use case cards from data.
 * Used on all service detail pages.
 * All content passed in — zero hardcoding.
 */
export interface Scenario {
  title: string;
  description: string;
  icon: string; // SVG path data
}

export interface Props {
  scenarios: Scenario[];
  heading?: string;
  eyebrow?: string;
  cta?: { label: string; href: string };
  light?: boolean;
}

const {
  scenarios,
  heading = 'Is This Right for You?',
  eyebrow = 'Best Fit',
  cta,
  light = false,
} = Astro.props;
---

<section class={`scenarios-section section-y ${light ? 'bg-light' : ''}`} aria-labelledby="scenarios-heading">
  <div class="container">
    <div class="scenarios-header">
      <div>
        <span class="eyebrow">{eyebrow}</span>
        <h2 id="scenarios-heading">{heading}</h2>
      </div>
      {cta && (
        <a href={cta.href} class="btn btn-outline scenarios-header-cta">
          {cta.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </div>

    <div class="scenarios-grid">
      {scenarios.map((scenario) => (
        <div class="scenario-card">
          <div class="scenario-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={scenario.icon} />
            </svg>
          </div>
          <h3 class="scenario-title">{scenario.title}</h3>
          <p class="scenario-desc">{scenario.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scenarios-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .scenarios-header h2 {
    margin: 0.3rem 0 0;
  }

  .scenarios-header-cta {
    flex-shrink: 0;
  }

  /* Dark variant */
  :not(.bg-light) .scenarios-header h2 {
    color: var(--color-white);
  }

  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.125rem;
  }

  .scenario-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }

  .scenario-card:hover {
    border-color: var(--color-border-gold);
    transform: translateY(-2px);
  }

  /* Light variant */
  .bg-light .scenario-card {
    background: #fff;
    border-color: rgba(0,0,0,0.08);
  }

  .bg-light .scenario-card:hover {
    border-color: var(--color-teal);
  }

  .scenario-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 3px;
    background: var(--color-gold-dim);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .bg-light .scenario-icon {
    background: rgba(13,148,136,0.1);
    color: var(--color-teal);
  }

  .scenario-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.625rem;
    line-height: 1.25;
  }

  .bg-light .scenario-title {
    color: #0B0C0F;
  }

  .scenario-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .bg-light .scenario-desc {
    color: #374151;
  }

  /* ─── Responsive ─────────────────────────── */
  @media (max-width: 1024px) {
    .scenarios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .scenarios-grid {
      grid-template-columns: 1fr;
    }

    .scenarios-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

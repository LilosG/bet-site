---
/**
 * ServiceCard — Reusable service card.
 * Used on homepage services section and services hub.
 */
export interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  index?: number;
}

import { cms } from '../../lib/cms';

const { title, description, href, icon, index = 0 } = Astro.props;
---

<a href={href} class="service-card card" style={`animation-delay: ${index * 80}ms`}>
  {icon && (
    <div class="service-icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d={icon} />
      </svg>
    </div>
  )}
  <div class="service-number" aria-hidden="true">0{index + 1}</div>
  <h3 class="service-title">{title}</h3>
  <p class="service-desc">{description}</p>
  <span class="service-learn-more">
    {cms.globalCtas.cardLearnMoreLabel}
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition-smooth);
    pointer-events: none;
  }

  .service-card:hover::after {
    border-color: var(--color-gold);
  }

  .service-icon {
    width: 40px;
    height: 40px;
    border-radius: 3px;
    background: var(--color-gold-dim);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    flex-shrink: 0;
    transition: background var(--transition-smooth);
  }

  .service-card:hover .service-icon {
    background: var(--color-teal-dim);
    color: var(--color-teal);
  }

  .service-number {
    position: absolute;
    top: 1rem;
    right: 1.125rem;
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-text-subtle);
    letter-spacing: 0.08em;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.625rem;
    line-height: 1.2;
    transition: color var(--transition-base);
  }

  .service-card:hover .service-title {
    color: var(--color-gold);
  }

  .service-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .service-learn-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    margin-top: auto;
    transition: color var(--transition-base), gap var(--transition-base);
  }

  .service-card:hover .service-learn-more {
    color: var(--color-gold);
    gap: 0.45rem;
  }
</style>

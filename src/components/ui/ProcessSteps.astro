---
/**
 * ProcessSteps.astro
 * Renders a numbered process timeline from data.
 * Used on all service detail pages.
 * All content passed in — zero hardcoding.
 */
export interface Step {
  step: number;
  title: string;
  description: string;
}

export interface Props {
  steps: Step[];
  heading?: string;
  eyebrow?: string;
  light?: boolean;
}

const {
  steps,
  heading = 'How It Works',
  eyebrow = 'The Process',
  light = false,
} = Astro.props;
---

<section class={`process-section section-y ${light ? 'bg-light' : 'bg-dark-2'}`} aria-labelledby="process-heading">
  <div class="container">
    <div class="process-header">
      <span class="eyebrow">{eyebrow}</span>
      <h2 id="process-heading">{heading}</h2>
    </div>

    <ol class="process-steps" role="list">
      {steps.map((s) => (
        <li class="process-step">
          <div class="step-number" aria-hidden="true">
            <span>{String(s.step).padStart(2, '0')}</span>
          </div>
          <div class="step-connector" aria-hidden="true"></div>
          <div class="step-content">
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process-header {
    margin-bottom: 3rem;
  }

  .process-header h2 {
    margin: 0.3rem 0 0;
  }

  /* Dark variant */
  .bg-dark-2 .process-header h2 {
    color: var(--color-white);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    padding-right: 1.5rem;
  }

  /* Connector line between steps */
  .step-connector {
    position: absolute;
    top: 1.375rem;
    left: calc(2.75rem + 1px);
    right: 1.5rem;
    height: 1px;
    background: var(--color-border);
  }

  .process-step:last-child .step-connector {
    display: none;
  }

  /* Number circle */
  .step-number {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1px solid var(--color-border-gold);
    background: var(--color-bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .step-number span {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-gold);
    letter-spacing: 0.04em;
  }

  /* Light variant number */
  .bg-light .step-number {
    background: #fff;
    border-color: var(--color-teal);
  }

  .bg-light .step-number span {
    color: var(--color-teal);
  }

  .bg-light .step-connector {
    background: rgba(0,0,0,0.1);
  }

  .step-content {
    padding-right: 0.5rem;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .bg-light .step-title {
    color: #0B0C0F;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .bg-light .step-desc {
    color: #374151;
  }

  /* ─── Responsive ─────────────────────────── */
  @media (max-width: 1100px) {
    .process-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem 0;
    }

    /* Hide connector on row-end items */
    .process-step:nth-child(3n) .step-connector {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .process-steps {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .process-step {
      flex-direction: row;
      gap: 1.25rem;
      padding-right: 0;
      padding-bottom: 2rem;
      align-items: flex-start;
    }

    /* Vertical connector for mobile */
    .step-connector {
      display: none;
    }

    .process-step::after {
      content: '';
      position: absolute;
      top: 2.75rem;
      left: 1.375rem;
      width: 1px;
      height: calc(100% - 2.75rem);
      background: var(--color-border);
    }

    .process-step:last-child::after {
      display: none;
    }

    .step-number {
      flex-shrink: 0;
      margin-bottom: 0;
    }

    .step-content {
      padding-top: 0.5rem;
      padding-right: 0;
    }
  }
</style>

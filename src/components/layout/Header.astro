---
/**
 * Header — Sticky nav, mega-dropdown, mobile drawer.
 * Supports optional group labels in dropdown children.
 * When children have a `group` field, the dropdown renders
 * a section label before the first child in each group.
 */
import { NAV, NAP, SITE } from '../../data/site';

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner container">

    <!-- Logo -->
    <a href="/" class="header-logo" aria-label={`${SITE.name} — Home`}>
      <img
        src="/images/logo.avif"
        alt="Beverage Equipment Traders"
        class="header-logo-img"
        width="148"
        height="44"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {NAV.primary.map((item) => (
          <li class={`nav-item${item.children ? ' has-dropdown' : ''}`}>
            <a
              href={item.href}
              class={`nav-link${isActive(item.href) ? ' is-active' : ''}`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
              {item.children && (
                <svg width="9" height="5" viewBox="0 0 9 5" fill="none" aria-hidden="true">
                  <path d="M1 1l3.5 3L8 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>

            {item.children && (
              <div class="dropdown" role="menu">
                <ul class="dropdown-list" role="list">
                  {item.children.map((child, i) => {
                    const prevChild = i > 0 ? item.children[i - 1] : null;
                    const showGroupLabel = 'group' in child && child.group &&
                      (!prevChild || !('group' in prevChild) || prevChild.group !== child.group);
                    return (
                      <>
                        {showGroupLabel && (
                          <li class="dropdown-group-label" role="none" aria-hidden="true">
                            {'group' in child ? child.group : ''}
                          </li>
                        )}
                        <li role="none">
                          <a
                            href={child.href}
                            class="dropdown-link"
                            role="menuitem"
                            target={'external' in child && child.external ? '_blank' : undefined}
                            rel={'external' in child && child.external ? 'noopener noreferrer' : undefined}
                          >
                            {child.label}
                            {'external' in child && child.external && (
                              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                              </svg>
                            )}
                          </a>
                        </li>
                      </>
                    );
                  })}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop Actions -->
    <div class="header-actions">
      <a href={`tel:${NAP.phonePlain}`} class="header-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 9.82 19.79 19.79 0 011.63 1.17 2 2 0 013.62 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        {NAP.phone}
      </a>
      <a href={NAV.cta.href} class="btn btn-primary btn-sm">{NAV.cta.label}</a>
    </div>

    <!-- Mobile Toggle -->
    <button
      class="mobile-toggle"
      id="mobile-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
    </button>
  </div>

  <!-- Mobile Nav Drawer -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
    <ul class="mobile-nav-list" role="list">
      {NAV.primary.map((item) => (
        <li class="mobile-nav-item">
          <a
            href={item.href}
            class={`mobile-nav-link${isActive(item.href) ? ' is-active' : ''}`}
          >
            {item.label}
          </a>
          {item.children && (
            <ul class="mobile-sub-list">
              {item.children.map((child, i) => {
                const prevChild = i > 0 ? item.children[i - 1] : null;
                const showGroupLabel = 'group' in child && child.group &&
                  (!prevChild || !('group' in prevChild) || prevChild.group !== child.group);
                return (
                  <>
                    {showGroupLabel && (
                      <li class="mobile-sub-group-label" aria-hidden="true">
                        {'group' in child ? child.group : ''}
                      </li>
                    )}
                    <li>
                      <a
                        href={child.href}
                        class="mobile-sub-link"
                        target={'external' in child && child.external ? '_blank' : undefined}
                        rel={'external' in child && child.external ? 'noopener noreferrer' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  </>
                );
              })}
            </ul>
          )}
        </li>
      ))}
      <li class="mobile-cta-item">
        <a href={NAV.cta.href} class="btn btn-primary" style="width:100%;">{NAV.cta.label}</a>
        <a href={`tel:${NAP.phonePlain}`} class="mobile-phone">{NAP.phone}</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle    = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.classList.toggle('is-open', !isOpen);
    mobileNav?.classList.toggle('is-open', !isOpen);
    mobileNav?.setAttribute('aria-hidden', String(isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('is-open');
      mobileNav?.classList.remove('is-open');
      mobileNav?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });

  document.addEventListener('click', (e) => {
    const header = document.getElementById('site-header');
    if (header && !header.contains(e.target as Node)) {
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('is-open');
      mobileNav?.classList.remove('is-open');
      mobileNav?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  /* ─── Header ─────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg-header);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }

  /* ─── Logo ─────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .header-logo-img {
    height: 38px;
    width: auto;
    display: block;
  }

  /* ─── Desktop Nav ──────────────────────── */
  .header-nav { flex: 1; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item { position: relative; }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    border-radius: var(--radius-sm);
    transition: color var(--transition-base), background var(--transition-base);
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-white);
    background: rgba(255,255,255,0.05);
  }

  .nav-link.is-active { color: var(--color-gold); background: transparent; }

  /* ─── Dropdown ─────────────────────────── */
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 16px 48px rgba(0,0,0,0.6);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--transition-smooth), transform var(--transition-smooth), visibility var(--transition-smooth);
    z-index: 50;
    overflow: hidden;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-list {
    padding: 0.375rem;
    list-style: none;
    margin: 0;
  }

  /* ─── Dropdown Group Label ─────────────── */
  .dropdown-group-label {
    font-family: var(--font-ui);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    padding: 0.625rem 0.875rem 0.25rem;
    display: block;
  }

  .dropdown-group-label:not(:first-child) {
    border-top: 1px solid var(--color-border);
    margin-top: 0.375rem;
    padding-top: 0.75rem;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5625rem 0.875rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: 3px;
    transition: color var(--transition-base), background var(--transition-base);
    white-space: nowrap;
  }

  .dropdown-link:hover {
    color: var(--color-white);
    background: rgba(255,255,255,0.06);
  }

  /* ─── Header Actions ───────────────────── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .header-phone {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
    white-space: nowrap;
  }

  .header-phone:hover { color: var(--color-gold); }

  /* ─── Mobile Toggle ────────────────────── */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    flex-shrink: 0;
    margin-left: auto;
  }

  .toggle-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-text-muted);
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
    transform-origin: center;
  }

  .mobile-toggle.is-open .toggle-bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .mobile-toggle.is-open .toggle-bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .mobile-toggle.is-open .toggle-bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ─── Mobile Nav Drawer ────────────────── */
  .mobile-nav {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 260ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 99;
  }

  .mobile-nav.is-open { transform: translateX(0); }

  .mobile-nav-list {
    padding: 1.25rem var(--container-pad) 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
  }

  .mobile-nav-item {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav-link {
    display: block;
    padding: 1rem 0;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.01em;
  }

  .mobile-nav-link.is-active { color: var(--color-gold); }

  .mobile-sub-list {
    padding: 0 0 0.75rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
  }

  /* ─── Mobile Group Label ───────────────── */
  .mobile-sub-group-label {
    font-family: var(--font-ui);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    padding: 0.625rem 0 0.2rem;
    display: block;
  }

  .mobile-sub-group-label:not(:first-child) {
    border-top: 1px solid var(--color-border);
    margin-top: 0.375rem;
  }

  .mobile-sub-link {
    display: block;
    padding: 0.4375rem 0;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .mobile-sub-link:hover { color: var(--color-teal); }

  .mobile-cta-item {
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-phone {
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: -0.01em;
  }

  /* ─── Responsive ───────────────────────── */
  @media (max-width: 1024px) {
    .header-phone { display: none; }
  }

  @media (max-width: 768px) {
    .header-nav     { display: none; }
    .header-actions { display: none; }
    .mobile-toggle  { display: flex; }
    .mobile-nav     { display: block; }
  }
</style>

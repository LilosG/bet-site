---
/**
 * Footer — Full footer with columns: equipment nav, services nav,
 * company info, canonical NAP. All content matches GBP exactly.
 */
import { Image } from 'astro:assets';
import { SITE, NAP, SOCIAL, HOURS } from '../../data/site';
import { EQUIPMENT_CATEGORIES } from '../../data/equipment';
import { SERVICES } from '../../data/services';
import { cms } from '../../lib/cms';
import { resolveCmsImage } from '../../lib/images';

const currentYear = new Date().getFullYear();
const content = cms.footer;
const logo = resolveCmsImage(SITE.logo);

const equipmentLinks = EQUIPMENT_CATEGORIES.slice(0, 6).map((c) => ({
  label: c.title,
  href:  `/equipment/${c.slug}`,
}));

const serviceLinks = SERVICES.map((s) => ({
  label: s.shortTitle,
  href:  `/services/${s.slug}`,
}));

const companyLinks = Array.isArray(content.companyLinks) ? content.companyLinks : [];
const legalLinks = Array.isArray(content.legalLinks) ? content.legalLinks : [];
const hours = Array.isArray(HOURS) ? HOURS : [];
const weekdayHours = hours.slice(0, 5);
const saturday = hours[5];
const sunday = hours[6];
---

<footer class="site-footer" itemscope itemtype="https://schema.org/LocalBusiness">
  <meta itemprop="name" content={SITE.name} />
  <meta itemprop="telephone" content={NAP.phonePlain} />
  <meta itemprop="url" content={SITE.url} />

  <!-- Top divider -->
  <div class="footer-top">
    <div class="container footer-top-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={`${SITE.name} — Home`}>
          {logo ? (
            <Image
              src={logo}
              alt={SITE.logoAlt}
              class="footer-logo-img"
              width="140"
              height="42"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="footer-logo-text">{SITE.shortName || SITE.name}</span>
          )}
        </a>
        <p class="footer-tagline">
          {content.tagline}
        </p>
        <div class="footer-socials">
          <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label={content.socialLabels.instagram} class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" aria-label={content.socialLabels.facebook} class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label={content.socialLabels.linkedin} class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Equipment -->
      <div class="footer-col">
        <h3 class="footer-col-heading">{content.equipmentHeading}</h3>
        <ul class="footer-links" role="list">
          {equipmentLinks.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
          <li>
            <a
              href={content.inventoryLink.href}
              class="footer-link footer-link-external"
              target="_blank"
              rel="noopener noreferrer"
            >
              {content.inventoryLink.label}
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M5 1H1v10h10V7M7 1h4m0 0v4m0-4L5 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h3 class="footer-col-heading">{content.servicesHeading}</h3>
        <ul class="footer-links" role="list">
          {serviceLinks.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
        <h3 class="footer-col-heading" style="margin-top:1.5rem;">{content.companyHeading}</h3>
        <ul class="footer-links" role="list">
          {companyLinks.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- NAP — matches GBP exactly -->
      <div class="footer-col footer-contact">
        <h3 class="footer-col-heading">{content.contactHeading}</h3>

        <address
          class="footer-address"
          itemprop="address"
          itemscope
          itemtype="https://schema.org/PostalAddress"
          not-italic
        >
          <span itemprop="name">{SITE.name},</span>
          <span itemprop="streetAddress">{NAP.street}</span>
          <span>
            <span itemprop="addressLocality">{NAP.city}</span>,
            <span itemprop="addressRegion">{NAP.state}</span>&nbsp;<span itemprop="postalCode">{NAP.zip}</span>
          </span>
        </address>

        <a
          href={`tel:${NAP.phonePlain}`}
          class="footer-phone"
          itemprop="telephone"
          aria-label={`Call us at ${NAP.phone}`}
        >
          {NAP.phone}
        </a>

        <a
          href={`mailto:${NAP.email}`}
          class="footer-email"
          itemprop="email"
        >
          {NAP.email}
        </a>

        <div class="footer-hours">
          <p class="footer-hours-label">{content.hoursHeading}</p>
          {weekdayHours.map((h) => (
            <div class="footer-hours-row">
              <span class="footer-hours-day">{h.day.slice(0,3)}</span>
              <span class="footer-hours-time">{h.label}</span>
            </div>
          ))}
          {saturday && (
            <div class="footer-hours-row">
              <span class="footer-hours-day">{saturday.day.slice(0,3)}</span>
              <span class="footer-hours-time">{content.saturdayShortLabel}</span>
            </div>
          )}
          {sunday && (
            <div class="footer-hours-row">
              <span class="footer-hours-day">{sunday.day.slice(0,3)}</span>
              <span class="footer-hours-time">{sunday.label}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copyright">
        &copy; {currentYear} {SITE.name}, {content.copyrightSuffix}
      </p>
      <nav aria-label={content.legalNavigationAriaLabel}>
        <ul class="footer-legal-links" role="list">
          {legalLinks.map(link => (
            <li><a href={link.href} class="footer-legal-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  /* ─── Top Section ──────────────────────── */
  .footer-top {
    padding: 4rem 0 3rem;
  }

  .footer-top-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.25fr;
    gap: 3rem;
    align-items: start;
  }

  /* ─── Brand Column ─────────────────────── */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .footer-logo-text {
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 800;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 28ch;
    margin-bottom: 1.25rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
    transition: border-color var(--transition-base), color var(--transition-base);
  }

  .social-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* ─── Nav Columns ──────────────────────── */
  .footer-col-heading {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.875rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .footer-link:hover {
    color: var(--color-white);
  }

  .footer-link-external {
    color: var(--color-teal);
  }

  .footer-link-external:hover {
    color: var(--color-gold);
  }

  /* ─── Contact Column ───────────────────── */
  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.875rem;
  }

  .footer-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    letter-spacing: 0.01em;
    margin-bottom: 0.375rem;
    transition: color var(--transition-base);
  }

  .footer-phone:hover {
    color: var(--color-gold-light);
  }

  .footer-email {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1.25rem;
    display: block;
    transition: color var(--transition-base);
  }

  .footer-email:hover {
    color: var(--color-white);
  }

  .footer-hours-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.5rem;
  }

  .footer-hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.125rem 0;
  }

  .footer-hours-day {
    color: var(--color-text-subtle);
    width: 2.5rem;
  }

  /* ─── Bottom Bar ───────────────────────── */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin: 0;
  }

  .footer-legal-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-legal-link {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-legal-link:hover {
    color: var(--color-text-muted);
  }

  /* ─── Responsive ───────────────────────── */
  @media (max-width: 1024px) {
    .footer-top-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 100%;
    }

    .footer-tagline {
      max-width: 40ch;
    }
  }

  @media (max-width: 600px) {
    .footer-top-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-legal-links {
      gap: 1rem;
    }
  }
</style>

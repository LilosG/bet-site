---
/**
 * Base Layout
 * All pages use this. Handles: meta, canonical, OG, schema injection,
 * global styles, fonts. Never duplicates anything.
 */
import type { SeoProps } from '../lib/seo';
import { buildTitle, buildCanonical, DEFAULT_OG_IMAGE } from '../lib/seo';
import { SITE, NAP, GEO } from '../data/site';
import { organizationSchema, schemaToScript } from '../lib/schema';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

export interface Props extends SeoProps {
  schemas?: object[];
  class?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = DEFAULT_OG_IMAGE,
  noindex = false,
  type = 'website',
  schemas = [],
  class: className,
} = Astro.props;

const pageTitle    = buildTitle(title);
const pageCanonical = buildCanonical(canonical ?? Astro.url.pathname);
const ogImageFull  = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;

// Always inject Organization schema
const allSchemas = [organizationSchema(), ...schemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={pageCanonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type"        content={type} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={pageCanonical} />
    <meta property="og:site_name"   content={SITE.name} />
    <meta property="og:image"       content={ogImageFull} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={pageTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageFull} />

    <!-- Business Contact -->
    <meta name="geo.region"    content="US-CA" />
    <meta name="geo.placename" content={`${NAP.city}, ${NAP.state}`} />
    <meta name="geo.position"  content={`${GEO.lat};${GEO.lng}`} />
    <meta name="ICBM"          content={`${GEO.lat}, ${GEO.lng}`} />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schemaToScript(schema)} />
    ))}

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={className}>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
